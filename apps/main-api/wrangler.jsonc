{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "main-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-13",
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "dev": {
    "port": 7878,
    "inspector_port": 9232
  },
  "env": {
    "staging": {
      "name": "main-api-staging"
    }
  }
