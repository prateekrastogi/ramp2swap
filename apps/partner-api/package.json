{
	"name": "partner-api",
	"type": "module",
	"scripts": {
		"setup:auth-local": "node ../../scripts/setup-partner-auth-local.mjs && wrangler d1 execute AUTH_DB --local --file ./migrations/0001_auth.sql",
		"dev": "npm run setup:auth-local && wrangler dev --local",
		"deploy": "wrangler deploy --minify",
		"cf-typegen": "wrangler types --env-interface CloudflareBindings"
	},
	"dependencies": {
		"hono": "^4.12.7"
	},
	"devDependencies": {
		"@types/node": "^25.5.0",
		"wrangler": "^4.73.0"
	}
}