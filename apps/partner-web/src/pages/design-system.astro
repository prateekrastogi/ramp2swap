---
import '../styles/design-system.css';

const transactions = [
  { id: 'TX-91A2', status: 'completed', amount: '$1,250.00', pair: 'USDC -> ETH', time: '2026-03-10 08:42 UTC', user: 'usr_x3f9•••' },
  { id: 'TX-91A3', status: 'pending', amount: '$480.00', pair: 'EUR -> USDT', time: '2026-03-10 08:31 UTC', user: 'usr_k2b1•••' },
  { id: 'TX-91A4', status: 'failed', amount: '$2,040.00', pair: 'USD -> BTC', time: '2026-03-10 08:09 UTC', user: 'usr_p8c7•••' },
  { id: 'TX-91A5', status: 'completed', amount: '$320.00', pair: 'GBP -> SOL', time: '2026-03-10 07:58 UTC', user: 'usr_w5m2•••' },
];

const topLinks = [
  { label: 'Main Campaign', pct: 76 },
  { label: 'Creator Drops', pct: 54 },
  { label: 'Telegram Push', pct: 39 },
  { label: 'Email Flow', pct: 24 },
];

const geos = [
  { label: 'India', pct: 34 },
  { label: 'UAE', pct: 21 },
  { label: 'UK', pct: 18 },
  { label: 'US', pct: 16 },
  { label: 'Other', pct: 11 },
];

const bars = [42, 60, 55, 72, 65, 84, 68, 76, 58, 80];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Ramp2Swap partner dashboard widget catalog" />
    <title>Design System | Partner Dashboard Widgets</title>
    <link rel="icon" type="image/png" href="/logo.png" />
  </head>
  <body class="page">
    <div class="ambient-layer" aria-hidden="true">
      <div class="ambient-orb ambient-orb--mint-top"></div>
      <div class="ambient-orb ambient-orb--blue-bottom"></div>
      <div class="ambient-orb ambient-orb--mint-center"></div>
    </div>

    <main class="container content-layer">
      <section class="glass glass-tier-2 on-glass section">
        <h1 class="heading-hero">Partner Dashboard Widgets</h1>
        <p class="body" style="margin-top: 10px; max-width: 820px;">
          Reference components required to build the partner portal. This page is a pre-implementation catalog for all core dashboard features.
        </p>
      </section>

      <section class="section" style="padding: 0; margin-top: 20px;">
        <h2 class="heading-section">1) Link Generator</h2>
        <div class="dashboard-grid">
          <article class="glass glass-tier-2 glass-mint card on-glass span-8 stack-16">
            <div class="widget-header">
              <p class="heading-card">Generate Referral Link</p>
              <span class="badge-active">Primary Widget</span>
            </div>

            <div class="stack-12">
              <label class="ui-label" for="partner-id">Partner ID</label>
              <input id="partner-id" class="input input-glass" value="partner_2swap_019" />
            </div>

            <div class="stack-12">
              <label class="ui-label" for="campaign-tag">Campaign Tag (optional)</label>
              <input id="campaign-tag" class="input input-glass" placeholder="spring-launch-2026" />
            </div>

            <div class="stack-12">
              <label class="ui-label" for="generated-link">Generated Link</label>
              <input id="generated-link" class="input input-glass" value="https://ramp2swap.com/r?pid=partner_2swap_019&cmp=spring-launch-2026" />
            </div>

            <div class="row-12">
              <button class="btn-primary btn-glass" type="button">Generate Link</button>
              <button class="btn-secondary" type="button">Copy Link</button>
              <button class="btn-secondary" type="button">Download QR</button>
            </div>
          </article>

          <article class="glass glass-tier-1 card on-glass span-4 stack-12">
            <p class="heading-card">Saved Campaign Links</p>
            <div class="stack-8">
              <div class="chip">Default / website-header</div>
              <div class="chip">influencer-drop / tg-01</div>
              <div class="chip">newsletter / mar-week-2</div>
              <div class="chip">community-call / post-event</div>
            </div>
          </article>
        </div>
      </section>

      <section class="section" style="padding: 0; margin-top: 20px;">
        <h2 class="heading-section">2) Dashboard Overview</h2>
        <article class="glass glass-tier-1 card on-glass stack-12">
          <p class="heading-card">KPI Snapshot</p>
          <div class="kpi-grid">
            <div class="kpi-card">
              <p class="ui-label">Total Clicks</p>
              <p class="data-large">48,220</p>
            </div>
            <div class="kpi-card">
              <p class="ui-label">Conversions</p>
              <p class="data-large">3,124</p>
            </div>
            <div class="kpi-card">
              <p class="ui-label">Volume Driven</p>
              <p class="data-large">$4.2M</p>
            </div>
            <div class="kpi-card">
              <p class="ui-label">Commission Balance</p>
              <p class="data-large">$28,940</p>
            </div>
          </div>
        </article>
      </section>

      <section class="section" style="padding: 0; margin-top: 20px;">
        <h2 class="heading-section">3) Transaction Feed</h2>
        <article class="glass glass-tier-1 card on-glass stack-12">
          <div class="widget-header">
            <p class="heading-card">Referral Transactions</p>
            <span class="chip">Anonymized users only</span>
          </div>

          <div class="table-wrap">
            <table class="table">
              <thead>
                <tr>
                  <th>Transaction</th>
                  <th>Status</th>
                  <th>Amount</th>
                  <th>Pair</th>
                  <th>Timestamp</th>
                  <th>User</th>
                </tr>
              </thead>
              <tbody>
                {transactions.map((tx) => (
                  <tr>
                    <td>{tx.id}</td>
                    <td>
                      <span class={`status ${tx.status === 'completed' ? 'status-completed' : tx.status === 'pending' ? 'status-pending' : 'status-failed'}`}>
                        {tx.status}
                      </span>
                    </td>
                    <td>{tx.amount}</td>
                    <td>{tx.pair}</td>
                    <td>{tx.time}</td>
                    <td>{tx.user}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </article>
      </section>

      <section class="section" style="padding: 0; margin-top: 20px;">
        <h2 class="heading-section">4) Earnings & Payouts</h2>
        <div class="dashboard-grid">
          <article class="glass glass-tier-2 glass-mint card on-glass span-7 stack-16">
            <p class="heading-card">Commission Summary</p>
            <div class="kpi-grid" style="grid-template-columns: repeat(3, minmax(0, 1fr));">
              <div class="kpi-card">
                <p class="ui-label">Commission Rate</p>
                <p class="data-large">18%</p>
              </div>
              <div class="kpi-card">
                <p class="ui-label">Pending</p>
                <p class="data-large">$7,420</p>
              </div>
              <div class="kpi-card">
                <p class="ui-label">Available</p>
                <p class="data-large">$21,520</p>
              </div>
            </div>
            <div class="row-12">
              <button class="btn-primary btn-glass" type="button">Request Withdrawal</button>
              <button class="btn-secondary" type="button">Export Payout CSV</button>
            </div>
          </article>

          <article class="glass glass-tier-1 card on-glass span-5 stack-12">
            <p class="heading-card">Recent Payouts</p>
            <div class="stack-8">
              <div class="row-12"><span class="data-small">2026-03-01</span><span class="chip">$8,600</span><span class="status status-completed">paid</span></div>
              <div class="row-12"><span class="data-small">2026-02-15</span><span class="chip">$7,900</span><span class="status status-completed">paid</span></div>
              <div class="row-12"><span class="data-small">2026-02-01</span><span class="chip">$6,870</span><span class="status status-completed">paid</span></div>
            </div>
          </article>
        </div>
      </section>

      <section class="section" style="padding: 0; margin-top: 20px; margin-bottom: 12px;">
        <h2 class="heading-section">5) Analytics</h2>
        <div class="dashboard-grid">
          <article class="glass glass-tier-1 card on-glass span-8 stack-12">
            <p class="heading-card">Clicks Over Time</p>
            <div class="chart-placeholder">
              <p class="data-small">Last 10 days</p>
              <div class="chart-bars">
                {bars.map((h) => (
                  <div class="bar" style={`height: ${h}%;`}></div>
                ))}
              </div>
              <p class="body-small">Conversion Rate: 6.48%</p>
            </div>
          </article>

          <article class="glass glass-tier-1 card on-glass span-4 stack-16">
            <div class="stack-12">
              <p class="heading-card">Top Performing Links</p>
              <div class="progress-list">
                {topLinks.map((item) => (
                  <div class="progress-row">
                    <div class="row-12" style="justify-content: space-between;"><span class="body-small">{item.label}</span><span class="data-small">{item.pct}%</span></div>
                    <div class="progress-track"><div class="progress-fill" style={`width: ${item.pct}%;`}></div></div>
                  </div>
                ))}
              </div>
            </div>

            <div class="stack-12">
              <p class="heading-card">Geographic Breakdown</p>
              <div class="progress-list">
                {geos.map((item) => (
                  <div class="progress-row">
                    <div class="row-12" style="justify-content: space-between;"><span class="body-small">{item.label}</span><span class="data-small">{item.pct}%</span></div>
                    <div class="progress-track"><div class="progress-fill" style={`width: ${item.pct}%;`}></div></div>
                  </div>
                ))}
              </div>
            </div>
          </article>
        </div>
      </section>
    </main>
  </body>
</html>
