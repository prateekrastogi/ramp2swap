---
import '../styles/design-system.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Ramp2Swap partner portal login" />
    <title>Partner Login | Ramp2Swap</title>
    <link rel="icon" type="image/png" href="/logo.png" />
  </head>
  <body class="page login-page">
    <div class="ambient-layer" aria-hidden="true">
      <div class="ambient-orb ambient-orb--mint-top"></div>
      <div class="ambient-orb ambient-orb--blue-bottom"></div>
      <div class="ambient-orb ambient-orb--mint-center"></div>
    </div>

    <main class="login-shell content-layer">
      <section class="login-panels" aria-label="Partner portal login">
        <article class="card glass glass-tier-4-nav on-glass login-showcase-panel">
          <div class="login-showcase-shell">
            <div class="login-showcase-main stack-16">
              <img class="logo-mark login-showcase-logo" src="/logo_verticle.png" alt="Ramp2Swap vertical logo" />
              <div class="login-asset-row" aria-label="Supported assets">
                <img class="login-asset-icon" src="/usdt.svg" alt="USDT" />
                <img class="login-asset-icon" src="/usdc.svg" alt="USDC" />
                <img class="login-asset-icon" src="/bitcoin.svg" alt="Bitcoin" />
                <img class="login-asset-icon" src="/bnb.svg" alt="BNB" />
                <img class="login-asset-icon" src="/ethereum.svg" alt="Ethereum" />
                <img class="login-asset-icon" src="/solana.svg" alt="Solana" />
              </div>
            </div>
          </div>
        </article>

        <article class="card glass glass-tier-3 on-glass login-form-panel">
          <div class="login-form-shell">
            <div class="stack-12">
              <h2 class="heading-card heading-section login-form-title">Partner Login</h2>
              <p class="body-small" data-login-feedback aria-live="polite"></p>
            </div>

            <form class="login-form stack-16" data-login-flow>
              <section class="login-step-shell stack-16" data-login-step="email">
                <div class="stack-12">
                  <label class="ui-label" for="partner-email">Email Address</label>
                  <input id="partner-email" class="input input-glass" data-login-email-input type="email" placeholder="partner@company.com" required />
                </div>

                <button class="btn-primary btn-glass login-submit" type="button" data-login-continue>Send OTP</button>
              </section>

              <section class="login-step-shell stack-16" data-login-step="password" hidden>
                <div class="stack-12">
                  <label class="ui-label" for="partner-otp">Email OTP</label>
                  <input id="partner-otp" class="input input-glass" data-login-otp-input type="text" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" placeholder="Enter the OTP sent to your email" required />
                </div>

                <button class="btn-primary btn-glass login-submit" type="submit">Verify OTP</button>
              </section>
            </form>
          </div>
        </article>
      </section>
    </main>

    <script>
      const loginFlow = document.querySelector('[data-login-flow]');
      if (loginFlow instanceof HTMLFormElement) {
        const emailStep = loginFlow.querySelector('[data-login-step="email"]');
        const passwordStep = loginFlow.querySelector('[data-login-step="password"]');
        const emailInput = loginFlow.querySelector('[data-login-email-input]');
        const otpInput = loginFlow.querySelector('[data-login-otp-input]');
        const continueButton = loginFlow.querySelector('[data-login-continue]');
        const feedbackNode = document.querySelector('[data-login-feedback]');

        const setFeedback = (message, isError = false) => {
          if (!(feedbackNode instanceof HTMLElement)) return;
          feedbackNode.textContent = message;
          feedbackNode.style.color = isError ? 'var(--color-status-danger)' : 'var(--color-text-secondary)';
        };

        const setBusy = (button, isBusy, busyLabel, idleLabel) => {
          if (!(button instanceof HTMLButtonElement)) return;
          button.disabled = isBusy;
          button.textContent = isBusy ? busyLabel : idleLabel;
        };

        const showPasswordStep = async () => {
          if (!(emailInput instanceof HTMLInputElement)) return;
          const emailValue = emailInput.value.trim();
          if (!emailValue) {
            emailInput.reportValidity();
            emailInput.focus();
            return;
          }

          setBusy(continueButton, true, 'Sending...', 'Send OTP');
          setFeedback('');

          try {
            const response = await fetch('/api/auth/request-otp', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
              },
              body: JSON.stringify({ email: emailValue }),
            });

            const payload = await response.json().catch(() => null);
            if (!response.ok || !payload?.ok) {
              setFeedback(payload?.error ?? 'Unable to send OTP right now.', true);
              return;
            }
          } catch {
            setFeedback('Unable to reach the login service.', true);
            return;
          } finally {
            setBusy(continueButton, false, 'Sending...', 'Send OTP');
          }

          if (emailStep instanceof HTMLElement) emailStep.hidden = true;
          if (passwordStep instanceof HTMLElement) passwordStep.hidden = false;
          setFeedback('Check your inbox and enter the 6-digit code.');
          if (otpInput instanceof HTMLInputElement) otpInput.focus();
        };

        if (continueButton instanceof HTMLButtonElement) {
          continueButton.addEventListener('click', () => {
            void showPasswordStep();
          });
        }

        loginFlow.addEventListener('submit', async (event) => {
          event.preventDefault();

          if (!(emailInput instanceof HTMLInputElement) || !(otpInput instanceof HTMLInputElement)) return;
          const emailValue = emailInput.value.trim();
          const otpValue = otpInput.value.trim();

          if (!otpValue) {
            otpInput.reportValidity();
            otpInput.focus();
            return;
          }

          const submitButton = passwordStep instanceof HTMLElement ? passwordStep.querySelector('.login-submit') : null;
          setBusy(submitButton, true, 'Verifying...', 'Verify OTP');
          setFeedback('');
          let didVerify = false;

          try {
            const response = await fetch('/api/auth/verify-otp', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
              },
              body: JSON.stringify({ email: emailValue, otp: otpValue }),
            });

            const payload = await response.json().catch(() => null);
            if (!response.ok || !payload?.ok) {
              setFeedback(payload?.error ?? 'Unable to verify OTP.', true);
              return;
            }

            didVerify = true;
            window.location.assign('/');
          } catch {
            setFeedback('Unable to reach the login service.', true);
          } finally {
            if (!didVerify) {
              setBusy(submitButton, false, 'Verifying...', 'Verify OTP');
            }
          }
        });
      }
    </script>
  </body>
</html>
