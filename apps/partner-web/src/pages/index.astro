---
import '../styles/design-system.css';
import {
  analyticsSummaries,
  geographicBreakdown,
  topPerformingLinks,
} from '../data/analytics-mock';
import { earningsSummary, payoutHistoryEntries } from '../data/earnings-payouts-mock';
import { linkGeneratorDraft, savedCampaignLinks } from '../data/link-generator-mock';
import { performanceSnapshotMetrics } from '../data/performance-snapshot-mock';
import { payoutDisplaySettings } from '../data/settings-display';
import { getPartnerApiBaseUrl } from '../lib/runtime-env';
import { transactionFeedItems } from '../data/transaction-feed-mock';

type PartnerSessionPayload = {
  ok?: boolean;
  email?: string;
  uid?: string;
  settings?: {
    username?: string;
    withdrawalAddress?: string;
    walletAddressUpdatedAt?: number | null;
    walletAddressCooldownEndsAt?: number | null;
    canUpdateWalletAddress?: boolean;
  };
};

const sessionToken = Astro.cookies.get('partner_session')?.value ?? '';
const partnerApiBaseUrl = await getPartnerApiBaseUrl();

const partnerSettings = {
  email: 'partners@ramp2swap.com',
  uid: '',
  username: 'prime-vault',
  withdrawalAddress: '',
  walletAddressUpdatedAt: null as number | null,
  walletAddressCooldownEndsAt: null as number | null,
  canUpdateWalletAddress: true,
};

if (sessionToken && partnerApiBaseUrl) {
  try {
    const response = await fetch(`${partnerApiBaseUrl}/auth/session`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({ sessionToken }),
    });

    const payload = (await response.json().catch(() => null)) as PartnerSessionPayload | null;
    if (response.ok && payload?.ok) {
      partnerSettings.email = payload.email ?? partnerSettings.email;
      partnerSettings.uid = payload.uid ?? partnerSettings.uid;
      partnerSettings.username = payload.settings?.username ?? partnerSettings.username;
      partnerSettings.withdrawalAddress = payload.settings?.withdrawalAddress ?? partnerSettings.withdrawalAddress;
      partnerSettings.walletAddressUpdatedAt = payload.settings?.walletAddressUpdatedAt ?? partnerSettings.walletAddressUpdatedAt;
      partnerSettings.walletAddressCooldownEndsAt =
        payload.settings?.walletAddressCooldownEndsAt ?? partnerSettings.walletAddressCooldownEndsAt;
      partnerSettings.canUpdateWalletAddress = payload.settings?.canUpdateWalletAddress ?? partnerSettings.canUpdateWalletAddress;
    }
  } catch (error) {
    console.warn('[partner-web] failed to load partner settings', error);
  }
}

const EMPTY_WALLET_ADDRESS_DISPLAY = 'Editable once every 7 days';
const walletAddressDisplayValue =
  partnerSettings.withdrawalAddress === '' ? EMPTY_WALLET_ADDRESS_DISPLAY : partnerSettings.withdrawalAddress;

const renderAnalyticsBars = (rangeKey: keyof typeof analyticsSummaries) =>
  analyticsSummaries[rangeKey].points
    .map(
      (point) => `
        <button
          class="bar-button"
          type="button"
          data-bar-label="${point.label}"
          data-bar-clicks="${point.clicks}"
          data-bar-conversion="${point.conversionRate}"
          aria-label="${point.label}: ${point.clicks} clicks, ${point.conversionRate} conversion rate"
          style="height: ${point.height}%"
        >
          <span class="bar-fill"></span>
        </button>
      `,
    )
    .join('');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Ramp2Swap partner portal" />
    <title>Partner Portal | Ramp2Swap</title>
    <link rel="icon" type="image/png" href="/logo.png" />
  </head>
  <body class="page">
    <input id="sidebar-collapse" class="sidebar-control" type="checkbox" />
    <input id="sidebar-pin" class="sidebar-control" type="checkbox" />
    <input id="sidebar-mobile" class="sidebar-control" type="checkbox" />

    <div class="ambient-layer" aria-hidden="true">
      <div class="ambient-orb ambient-orb--mint-top"></div>
      <div class="ambient-orb ambient-orb--blue-bottom"></div>
      <div class="ambient-orb ambient-orb--mint-center"></div>
    </div>

    <header class="mobile-topbar content-layer">
      <button class="hamburger-btn" id="mobile-sidebar-toggle" type="button" aria-label="Open navigation">
        <svg class="hamburger-icon" viewBox="0 0 24 24" aria-hidden="true">
          <line class="hamburger-line hamburger-line-top" x1="5" y1="7" x2="19" y2="7"></line>
          <line class="hamburger-line hamburger-line-mid" x1="5" y1="12" x2="19" y2="12"></line>
          <line class="hamburger-line hamburger-line-bottom" x1="5" y1="17" x2="19" y2="17"></line>
        </svg>
      </button>
      <button class="mobile-topbar-logo-toggle" id="mobile-logo-toggle" type="button" aria-label="Toggle navigation">
        <img class="logo-mark mobile-topbar-mark" src="/logo.png" alt="Ramp2Swap mark" />
      </button>
    </header>

    <label for="sidebar-mobile" class="mobile-overlay" aria-hidden="true"></label>

    <main class="dashboard-shell content-layer">
      <aside class="sidebar glass glass-tier-4-nav on-glass">
        <button class="sidebar-brand" id="sidebar-brand-toggle" type="button" aria-label="Toggle navigation">
          <img class="logo-horizontal sidebar-logo-horizontal" src="/logo_horizontal.png" alt="Ramp2Swap" />
          <img class="logo-mark sidebar-logo-mark" src="/logo.png" alt="Ramp2Swap mark" />
        </button>

        <nav class="sidebar-nav" aria-label="Primary navigation">
          <section class="nav-section">
            <a class="nav-item nav-item-active" href="#overview" data-label="Overview" data-view-target="overview"><span class="nav-icon">◫</span><span class="nav-text">Overview</span></a>
            <a class="nav-item" href="#link-generator" data-label="Link Generator" data-view-target="link-generator"><span class="nav-icon nav-icon-text">⛓︎</span><span class="nav-text">Link Generator</span></a>
            <a class="nav-item" href="#transaction-feed" data-label="Transaction Feed" data-view-target="transaction-feed"><span class="nav-icon">⇄</span><span class="nav-text">Transaction Feed</span></a>
            <a class="nav-item" href="#earnings-payouts" data-label="Earnings & Payouts" data-view-target="earnings-payouts"><span class="nav-icon">$</span><span class="nav-text">Earnings & Payouts</span></a>
            <a class="nav-item" href="#analytics" data-label="Analytics" data-view-target="analytics"><span class="nav-icon">◔</span><span class="nav-text">Analytics</span></a>
          </section>
        </nav>

        <div class="sidebar-bottom">
          <a class="nav-item" href="#settings" data-label="Settings" data-view-target="settings"><span class="nav-icon">⚙</span><span class="nav-text">Settings</span></a>
          <a class="nav-item" href="mailto:help@ramp2swap.com" data-label="Help"><span class="nav-icon">i</span><span class="nav-text">Help</span></a>

          <div class="sidebar-profile" data-label="Profile">
            <img class="sidebar-avatar" data-sidebar-avatar alt="Partner identicon" />
            <span class="profile-copy">
              <span class="profile-name" data-profile-name>{partnerSettings.username}</span>
              <span class="profile-role">PRO PLAN</span>
            </span>
            <button class="sidebar-logout" type="button" aria-label="Logout" data-label="Logout">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M14 7l5 5-5 5"></path>
                <path d="M19 12H9"></path>
                <path d="M12 5H6a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h6"></path>
              </svg>
            </button>
          </div>
        </div>
      </aside>

      <section class="dashboard-content" aria-label="Dashboard content area">
        <div class="dashboard-main">
          <section id="overview" class="overview-shell" data-dashboard-view="overview">
            <div class="dashboard-section-header">
              <div class="stack-12">
                <p class="ui-label">Overview</p>
                <h1 class="heading-card heading-section dashboard-section-title">Partner Performance Snapshot</h1>
                <p class="body dashboard-section-copy">
                  Core referral performance metrics for the current reporting window.
                </p>
              </div>
            </div>

            <div class="performance-metrics-grid">
              {performanceSnapshotMetrics.map((metric) => (
                <article class={`card performance-metric-card glass glass-interactive ${metric.accent === 'mint' ? 'glass-tier-2 glass-highlight-soft performance-metric-card-highlight' : 'glass-tier-1'} on-glass`}>
                  <div class="performance-metric-card-top">
                    <p class="ui-label">{metric.label}</p>
                    <span class={`performance-metric-delta ${metric.accent === 'mint' ? 'performance-metric-delta-accent' : ''}`}>{metric.delta}</span>
                  </div>
                  <p class="data-large performance-metric-value">{metric.value}</p>
                  <p class="body-small performance-metric-detail">{metric.detail}</p>
                </article>
              ))}
            </div>
          </section>

          <section id="link-generator" class="link-generator-shell" data-dashboard-view="link-generator" hidden>
            <div class="dashboard-section-header">
              <div class="stack-12">
                <p class="ui-label">Link Generator</p>
                <h2 class="heading-card heading-section dashboard-section-title">Generate Referral Links</h2>
                <p class="body dashboard-section-copy">
                  Create partner-specific referral URLs, append campaign tags, and manage active links.
                </p>
              </div>
            </div>

            <div class="link-generator-grid">
              <article class="card glass glass-tier-2 glass-mint glass-interactive on-glass link-generator-card">
                <div class="widget-header">
                  <p class="heading-card">Primary Link Builder</p>
                  <span class="badge-active">Core Flow</span>
                </div>

                <div
                  class="link-form-grid"
                  data-link-generator
                  data-base-url={linkGeneratorDraft.baseUrl}
                  data-partner-username={partnerSettings.username}
                >
                  <div class="stack-12">
                    <label class="ui-label" for="campaign-name">CAMPAIGN NAME</label>
                    <div class="link-input-shell" data-link-field>
                      <input
                        id="campaign-name"
                        class="input input-glass"
                        data-link-campaign-name
                        value={linkGeneratorDraft.campaignName}
                      />
                      <span class="link-input-warning" data-link-warning-icon aria-hidden="true">
                        <svg viewBox="0 0 24 24" focusable="false">
                          <path d="M12 4 3.5 19h17L12 4Z"></path>
                          <path d="M12 9v5"></path>
                          <path d="M12 17h.01"></path>
                        </svg>
                      </span>
                    </div>
                  </div>

                  <div class="stack-12">
                    <label class="ui-label" for="campaign-tag">Campaign Tag</label>
                    <div class="link-input-shell" data-link-field>
                      <input
                        id="campaign-tag"
                        class="input input-glass"
                        data-link-campaign-tag
                        value={linkGeneratorDraft.campaignTag}
                      />
                      <span class="link-input-warning" data-link-warning-icon aria-hidden="true">
                        <svg viewBox="0 0 24 24" focusable="false">
                          <path d="M12 4 3.5 19h17L12 4Z"></path>
                          <path d="M12 9v5"></path>
                          <path d="M12 17h.01"></path>
                        </svg>
                      </span>
                    </div>
                  </div>

                  <div class="stack-12 link-output-block">
                    <label class="ui-label" for="generated-link">Generated Referral URL</label>
                    <div class="link-output-shell">
                      <input
                        id="generated-link"
                        class="input input-glass link-output-input"
                        data-generated-link
                        value={linkGeneratorDraft.generatedUrl}
                        readonly
                      />
                      <div class="link-output-actions">
                        <button class="btn-primary btn-glass" type="button" data-generate-link>Generate Link</button>
                        <button class="btn-secondary" type="button" data-copy-generated-link>Copy Link</button>
                        <button class="btn-secondary" type="button" data-download-qr>Download QR</button>
                      </div>
                    </div>
                  </div>
                </div>
              </article>

              <article class="card glass glass-tier-1 glass-interactive on-glass link-campaigns-card">
                <div class="widget-header">
                  <p class="heading-card">Saved Campaign Links</p>
                  <span class="chip">{savedCampaignLinks.length} active</span>
                </div>

                <div class="link-campaign-list">
                  {savedCampaignLinks.map((link) => (
                    <article class="link-campaign-row">
                      <div class="link-campaign-head">
                        <div class="stack-8">
                          <p class="heading-card">{link.name}</p>
                          <p class="data-small">{link.tag}</p>
                        </div>
                        <span class="link-inline-stat">{link.clicks} clicks</span>
                      </div>

                      <p class="link-url">{link.url}</p>

                      <div class="link-campaign-meta">
                        <span class="link-inline-stat">{link.conversions} conversions</span>
                        <button class="btn-secondary link-inline-btn" type="button" data-copy-text={link.url}>Copy</button>
                      </div>
                    </article>
                  ))}
                </div>
              </article>
            </div>
          </section>

          <section id="transaction-feed" class="transaction-feed-shell" data-dashboard-view="transaction-feed" hidden>
            <div class="dashboard-section-header">
              <div class="stack-12">
                <p class="ui-label">Transaction Feed</p>
                <h2 class="heading-card heading-section dashboard-section-title">Live Processing Status</h2>
                <p class="body dashboard-section-copy transaction-feed-copy">
                  Every ramp transaction attributed to your referral links, with anonymized user references and current processing status.
                </p>
              </div>
            </div>

            <article class="card glass glass-tier-1 glass-interactive on-glass transaction-feed-card">
              <div class="widget-header">
                <p class="heading-card">Referral Stream</p>
                <span class="chip">{transactionFeedItems.length} recent entries</span>
              </div>

              <div class="table-wrap transaction-table-wrap">
                <table class="table">
                  <thead>
                    <tr>
                      <th>Transaction</th>
                      <th>Status</th>
                      <th>Amount</th>
                      <th>Pair</th>
                      <th>Timestamp</th>
                      <th>User</th>
                    </tr>
                  </thead>
                  <tbody>
                    {transactionFeedItems.map((tx) => (
                      <tr>
                        <td>{tx.id}</td>
                        <td>
                          <span class={`status ${tx.status === 'completed' ? 'status-completed' : tx.status === 'pending' ? 'status-pending' : 'status-failed'}`}>
                            {tx.status}
                          </span>
                        </td>
                        <td>{tx.amount}</td>
                        <td>{tx.pair}</td>
                        <td>{tx.timestamp}</td>
                        <td>{tx.user}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </article>
          </section>

          <section id="earnings-payouts" class="earnings-payouts-shell" data-dashboard-view="earnings-payouts" hidden>
            <div class="dashboard-section-header">
              <div class="stack-12">
                <p class="ui-label">Earnings & Payouts</p>
                <h2 class="heading-card heading-section dashboard-section-title">Commission and Withdrawal Status</h2>
                <p class="body dashboard-section-copy earnings-payouts-copy">
                  Review your commission rate, compare pending versus available balance, and track payout history before requesting withdrawal.
                </p>
              </div>
            </div>

            <div class="earnings-payouts-grid">
              <article class="card glass glass-tier-2 glass-mint glass-interactive on-glass revenue-summary-card">
                <div class="widget-header">
                  <p class="heading-card">Revenue Summary</p>
                  <span class="badge-active">Action Surface</span>
                </div>

                <div class="kpi-grid earnings-kpi-grid">
                  <div class="kpi-card">
                    <p class="ui-label">Commission Rate</p>
                    <p class="data-large">{earningsSummary.commissionRate}</p>
                  </div>
                  <div class="kpi-card">
                    <p class="ui-label">Pending Balance</p>
                    <p class="data-large">{earningsSummary.pendingBalance}</p>
                  </div>
                  <div class="kpi-card">
                    <p class="ui-label">Available Balance</p>
                    <p class="data-large">{earningsSummary.availableBalance}</p>
                  </div>
                  <div class="kpi-card">
                    <p class="ui-label">Total Paid Out</p>
                    <p class="data-large">{earningsSummary.totalPaidOut}</p>
                  </div>
                </div>

                <div class="row-12">
                  <button class="btn-primary btn-glass" type="button">Request Withdrawal</button>
                </div>
              </article>

              <article class="card glass glass-tier-1 glass-interactive on-glass payout-history-card">
                <div class="widget-header">
                  <p class="heading-card">Payout History</p>
                  <span class="chip">{payoutHistoryEntries.length} entries</span>
                </div>

                <div class="payout-history-list">
                  {payoutHistoryEntries.map((entry) => (
                    <article class="payout-history-row">
                      <div class="payout-history-head">
                        <div class="stack-8">
                          <p class="heading-card">{entry.amount}</p>
                          <p class="data-small">{entry.destination}</p>
                        </div>
                        <span class={`status ${entry.status === 'paid' ? 'status-completed' : 'status-pending'}`}>
                          {entry.status}
                        </span>
                      </div>

                      <div class="row-12 payout-history-meta">
                        <span class="data-small">{entry.date}</span>
                        <span class="chip">{entry.id}</span>
                      </div>
                    </article>
                  ))}
                </div>
              </article>
            </div>
          </section>

          <section id="analytics" class="analytics-shell" data-dashboard-view="analytics" hidden>
            <div class="dashboard-section-header">
              <div class="stack-12">
                <p class="ui-label">Analytics</p>
                <h2 class="heading-card heading-section dashboard-section-title">Traffic and Conversion Insights</h2>
                <p class="body dashboard-section-copy">
                  Analyze click momentum, conversion rate, top performing links, and user geography across your referral campaigns.
                </p>
              </div>
            </div>

            <div class="analytics-grid">
              <article
                class="card glass glass-tier-1 glass-interactive on-glass analytics-chart-card"
                data-analytics-chart
                data-analytics-ranges={JSON.stringify(analyticsSummaries)}
              >
                <div class="widget-header">
                  <p class="heading-card">Clicks Over Time</p>
                  <div class="analytics-range-toggle" role="tablist" aria-label="Analytics range">
                    <button class="analytics-range-button" type="button" data-range-toggle="10D">10D</button>
                    <button class="analytics-range-button analytics-range-button-active" type="button" data-range-toggle="30D">30D</button>
                    <button class="analytics-range-button" type="button" data-range-toggle="90D">90D</button>
                  </div>
                </div>

                <div class="chart-placeholder">
                  <p class="data-small" data-analytics-range-label>{analyticsSummaries['30D'].timeRangeLabel}</p>
                  <div
                    class="chart-bars"
                    data-analytics-bars
                    set:html={renderAnalyticsBars('30D')}
                  ></div>
                </div>
              </article>

              <article class="card glass glass-tier-2 glass-interactive glass-highlight-soft analytics-top-links-card on-glass">
                <div class="stack-12">
                  <p class="heading-card">Top Performing Links</p>
                  <div class="progress-list">
                    {topPerformingLinks.map((item) => (
                      <div class="progress-row">
                        <div class="row-12 analytics-progress-head">
                          <span class="body-small">{item.label}</span>
                          <span class="data-small">{item.pct}%</span>
                        </div>
                        <div class="progress-track">
                          <div class="progress-fill" style={`width: ${item.pct}%;`}></div>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              </article>

              <article class="card glass glass-tier-1 glass-interactive on-glass analytics-breakdown-card analytics-geo-card">
                <div class="stack-12">
                  <p class="heading-card">Geographic Breakdown</p>
                  <div class="progress-list">
                    {geographicBreakdown.map((item) => (
                      <div class="progress-row">
                        <div class="row-12 analytics-progress-head">
                          <span class="body-small">{item.label}</span>
                          <span class="data-small">{item.pct}%</span>
                        </div>
                        <div class="progress-track">
                          <div class="progress-fill" style={`width: ${item.pct}%;`}></div>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              </article>
            </div>
          </section>

          <section id="settings" class="settings-shell" data-dashboard-view="settings" hidden>
            <div class="dashboard-section-header">
              <div class="stack-12">
                <p class="ui-label">Settings</p>
                <h2 class="heading-card heading-section dashboard-section-title">Partner Settings Control Center</h2>
                <p class="body dashboard-section-copy">
                  Manage identity details and payout configuration for your partner account.
                </p>
              </div>
            </div>

            <div class="settings-grid">
              <aside class="card glass glass-tier-3 glass-interactive on-glass settings-nav-card">
                <div class="stack-12">
                  <button class="settings-nav-button settings-nav-button-active" type="button" data-settings-target="profile">
                    <span class="settings-nav-copy">
                      <span class="heading-card">Profile & Identity</span>
                      <span class="body-small">Username and login email used for your partner account.</span>
                    </span>
                  </button>

                  <button class="settings-nav-button" type="button" data-settings-target="payouts">
                    <span class="settings-nav-copy">
                      <span class="heading-card">Payout Configuration</span>
                      <span class="body-small">Wallet routing, thresholds, and payout schedule.</span>
                    </span>
                  </button>
                </div>
              </aside>

              <div class="settings-panel-stack">
                <section class="settings-panel" data-settings-panel="profile">
                  <article class="card glass glass-tier-3 glass-interactive on-glass settings-feature-card">
                    <div class="widget-header">
                      <p class="heading-card">Profile & Identity</p>
                    </div>
                    <div class="settings-feature-grid">
                      <div class="settings-field-card">
                        <p class="ui-label">Display Name</p>
                        <p class="data-large settings-field-value">{partnerSettings.username}</p>
                      </div>
                      <div class="settings-field-card">
                        <p class="ui-label">Email Address</p>
                        <p class="body settings-field-body">{partnerSettings.email}</p>
                      </div>
                    </div>
                  </article>
                </section>

                <section class="settings-panel" data-settings-panel="payouts" hidden>
                  <article class="card glass glass-tier-3 glass-interactive on-glass settings-feature-card">
                    <div class="widget-header">
                      <p class="heading-card">Payout Configuration</p>
                    </div>

                    <div class="settings-feature-grid">
                      <div class="settings-field-card">
                        <p class="ui-label">Preferred Asset</p>
                        <p class="data-large settings-field-value">{payoutDisplaySettings.walletAsset}</p>
                      </div>
                      <div class="settings-field-card">
                        <div class="settings-field-card-head">
                          <p class="ui-label">Wallet Address</p>
                          <button
                            class="settings-edit-button settings-edit-button-tooltip"
                            type="button"
                            aria-label="Edit wallet address"
                            data-label="Edit wallet address"
                            data-wallet-address-can-update={partnerSettings.canUpdateWalletAddress ? 'true' : 'false'}
                            data-wallet-address-cooldown-ends-at={partnerSettings.walletAddressCooldownEndsAt ?? ''}
                            data-wallet-address-toggle
                          >
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                              <path d="M4 20h4l10-10-4-4L4 16v4Z"></path>
                              <path d="M13 7l4 4"></path>
                            </svg>
                          </button>
                        </div>
                        <p class="body settings-field-body" data-wallet-address-value>{walletAddressDisplayValue}</p>
                        <input
                          class="input input-glass surface-mint-muted settings-wallet-input"
                          type="text"
                          value={partnerSettings.withdrawalAddress}
                          placeholder={EMPTY_WALLET_ADDRESS_DISPLAY}
                          aria-label="Wallet address"
                          data-wallet-address-input
                          hidden
                        />
                      </div>
                      <div class="settings-field-card">
                        <p class="ui-label">Payout Network</p>
                        <p class="body settings-field-body">{payoutDisplaySettings.network}</p>
                      </div>
                      <div class="settings-field-card">
                        <p class="ui-label">Minimum Threshold</p>
                        <p class="body settings-field-body">{payoutDisplaySettings.minimumThreshold}</p>
                      </div>
                    </div>
                  </article>
                </section>
              </div>
            </div>
          </section>
        </div>
      </section>
    </main>

    <script>
      const collapseControl = document.getElementById('sidebar-collapse');
      if (collapseControl instanceof HTMLInputElement && window.matchMedia('(min-width: 1280px)').matches) {
        collapseControl.checked = false;
      }

      const mobileSidebarToggle = document.getElementById('mobile-sidebar-toggle');
      const mobileLogoToggle = document.getElementById('mobile-logo-toggle');
      const sidebarBrandToggle = document.getElementById('sidebar-brand-toggle');
      const sidebarLogoutButton = document.querySelector('.sidebar-logout');
      const sidebarElement = document.querySelector('.sidebar');
      const mobileTopbar = document.querySelector('.mobile-topbar');
      const mobileControl = document.getElementById('sidebar-mobile');
      const pinControl = document.getElementById('sidebar-pin');
      const navViewTriggers = document.querySelectorAll('[data-view-target]');
      const dashboardViews = document.querySelectorAll('[data-dashboard-view]');
      const profileNameNode = document.querySelector('[data-profile-name]');
      const sidebarAvatar = document.querySelector('[data-sidebar-avatar]');
      const settingsViewTriggers = document.querySelectorAll('[data-settings-target]');
      const settingsPanels = document.querySelectorAll('[data-settings-panel]');

      if (profileNameNode instanceof HTMLElement && sidebarAvatar instanceof HTMLImageElement) {
        const usernameSeed = profileNameNode.textContent?.trim() || 'prime-vault';
        sidebarAvatar.src = `https://api.dicebear.com/9.x/identicon/svg?seed=${encodeURIComponent(usernameSeed)}`;
      }

      if (
        sidebarBrandToggle instanceof HTMLButtonElement &&
        mobileControl instanceof HTMLInputElement &&
        pinControl instanceof HTMLInputElement
      ) {
        sidebarBrandToggle.addEventListener('click', () => {
          if (window.matchMedia('(max-width: 767px)').matches) {
            mobileControl.checked = !mobileControl.checked;
            return;
          }

          if (window.matchMedia('(min-width: 768px) and (max-width: 1279px)').matches) {
            pinControl.checked = !pinControl.checked;
            return;
          }

          if (collapseControl instanceof HTMLInputElement) {
            collapseControl.checked = !collapseControl.checked;
          }
        });
      }

      if (mobileSidebarToggle instanceof HTMLButtonElement && mobileControl instanceof HTMLInputElement) {
        mobileSidebarToggle.addEventListener('click', (event) => {
          event.stopPropagation();
          mobileControl.checked = !mobileControl.checked;
        });
      }

      if (mobileLogoToggle instanceof HTMLButtonElement && mobileControl instanceof HTMLInputElement) {
        mobileLogoToggle.addEventListener('click', (event) => {
          event.stopPropagation();
          mobileControl.checked = !mobileControl.checked;
        });
      }

      if (sidebarLogoutButton instanceof HTMLButtonElement) {
        sidebarLogoutButton.addEventListener('click', async () => {
          sidebarLogoutButton.disabled = true;

          try {
            await fetch('/api/auth/logout', {
              method: 'POST',
              credentials: 'same-origin',
            });
          } finally {
            window.location.replace('/login');
          }
        });
      }

      document.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof Node) || !(sidebarElement instanceof HTMLElement)) {
          return;
        }

        const clickedInsideSidebar = sidebarElement.contains(target);
        const clickedMobileTopbar = mobileTopbar instanceof HTMLElement && mobileTopbar.contains(target);

        if (
          pinControl instanceof HTMLInputElement &&
          pinControl.checked &&
          window.matchMedia('(min-width: 768px) and (max-width: 1279px)').matches &&
          !clickedInsideSidebar
        ) {
          pinControl.checked = false;
        }

        if (
          mobileControl instanceof HTMLInputElement &&
          mobileControl.checked &&
          window.matchMedia('(max-width: 767px)').matches &&
          !clickedInsideSidebar &&
          !clickedMobileTopbar
        ) {
          mobileControl.checked = false;
        }
      });

      if (navViewTriggers.length > 0 && dashboardViews.length > 0) {
        const setActiveView = (viewName) => {
          navViewTriggers.forEach((trigger) => {
            const isActive = trigger.getAttribute('data-view-target') === viewName;
            trigger.classList.toggle('nav-item-active', isActive);
          });

          dashboardViews.forEach((view) => {
            view.hidden = view.getAttribute('data-dashboard-view') !== viewName;
          });

          if (mobileControl instanceof HTMLInputElement && window.matchMedia('(max-width: 767px)').matches) {
            mobileControl.checked = false;
          }
        };

        navViewTriggers.forEach((trigger) => {
          trigger.addEventListener('click', (event) => {
            const target = trigger.getAttribute('data-view-target');
            if (!target) return;
            event.preventDefault();
            setActiveView(target);
          });
        });
      }

      if (settingsViewTriggers.length > 0 && settingsPanels.length > 0) {
        const setActiveSettingsPanel = (panelName) => {
          settingsViewTriggers.forEach((trigger) => {
            const isActive = trigger.getAttribute('data-settings-target') === panelName;
            trigger.classList.toggle('settings-nav-button-active', isActive);
          });

          settingsPanels.forEach((panel) => {
            panel.hidden = panel.getAttribute('data-settings-panel') !== panelName;
          });
        };

        settingsViewTriggers.forEach((trigger) => {
          trigger.addEventListener('click', () => {
            const target = trigger.getAttribute('data-settings-target');
            if (!target) return;
            setActiveSettingsPanel(target);
          });
        });
      }

      const walletAddressCard = document.querySelector('[data-wallet-address-toggle]')?.closest('.settings-field-card');
      const walletAddressToggle = document.querySelector('[data-wallet-address-toggle]');
      const walletAddressValue = document.querySelector('[data-wallet-address-value]');
      const walletAddressInput = document.querySelector('[data-wallet-address-input]');

      if (
        walletAddressCard instanceof HTMLElement &&
        walletAddressToggle instanceof HTMLButtonElement &&
        walletAddressValue instanceof HTMLElement &&
        walletAddressInput instanceof HTMLInputElement
      ) {
        const emptyWalletAddressDisplay = 'Editable once every 7 days';
        const editIcon = `
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4 20h4l10-10-4-4L4 16v4Z"></path>
            <path d="M13 7l4 4"></path>
          </svg>
        `;
        const saveIcon = `
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="m5 12 4 4L19 6"></path>
          </svg>
        `;

        let currentWalletAddress = walletAddressInput.value.trim();
        let isSavingWalletAddress = false;
        let walletAddressCooldownEndsAt = Number(walletAddressToggle.dataset.walletAddressCooldownEndsAt || '') || null;
        let cooldownTimer = null;

        const getWalletAddressDisplayValue = (value) => (value === '' ? emptyWalletAddressDisplay : value);

        const formatRelativeDuration = (milliseconds) => {
          const totalMinutes = Math.max(1, Math.ceil(milliseconds / (1000 * 60)));
          const days = Math.floor(totalMinutes / (24 * 60));
          const hours = Math.floor((totalMinutes % (24 * 60)) / 60);
          const minutes = totalMinutes % 60;

          return `${days}D ${hours}H ${minutes}M`;
        };

        const getWalletButtonLabel = (isEditing, canUpdate) => {
          if (isEditing) {
            return 'Save wallet address';
          }

          if (!canUpdate && typeof walletAddressCooldownEndsAt === 'number' && walletAddressCooldownEndsAt > Date.now()) {
            return `Editable in ${formatRelativeDuration(walletAddressCooldownEndsAt - Date.now())}`;
          }

          return 'Edit wallet address';
        };

        const syncWalletCooldownState = () => {
          const now = Date.now();
          const canUpdate = typeof walletAddressCooldownEndsAt !== 'number' || walletAddressCooldownEndsAt <= now;
          const isEditing = !walletAddressInput.hidden;
          const buttonLabel = getWalletButtonLabel(isEditing, canUpdate);

          walletAddressToggle.dataset.walletAddressCanUpdate = canUpdate ? 'true' : 'false';
          walletAddressToggle.dataset.walletAddressCooldownEndsAt = walletAddressCooldownEndsAt ? String(walletAddressCooldownEndsAt) : '';
          walletAddressToggle.dataset.label = buttonLabel;
          walletAddressToggle.setAttribute('aria-label', buttonLabel);

          if (isSavingWalletAddress) {
            walletAddressToggle.disabled = true;
            walletAddressInput.disabled = true;
          } else {
            walletAddressToggle.disabled = false;
            walletAddressInput.disabled = !canUpdate && !isEditing;
          }

          if (cooldownTimer !== null) {
            window.clearTimeout(cooldownTimer);
            cooldownTimer = null;
          }

          if (!canUpdate && typeof walletAddressCooldownEndsAt === 'number') {
            const millisecondsUntilNextMinute = 60_000 - (now % 60_000);
            const nextRefreshDelay = Math.min(
              Math.max(millisecondsUntilNextMinute, 1_000),
              Math.max(walletAddressCooldownEndsAt - now, 1_000),
            );
            cooldownTimer = window.setTimeout(syncWalletCooldownState, nextRefreshDelay);
          }

          return canUpdate;
        };

        const setWalletEditMode = (isEditing) => {
          walletAddressValue.hidden = isEditing;
          walletAddressInput.hidden = !isEditing;
          walletAddressToggle.innerHTML = isEditing ? saveIcon : editIcon;
          syncWalletCooldownState();

          if (isEditing) {
            walletAddressInput.placeholder = emptyWalletAddressDisplay;
            walletAddressInput.value = currentWalletAddress;
          } else {
            walletAddressValue.textContent = getWalletAddressDisplayValue(currentWalletAddress);
          }

          if (isEditing) {
            walletAddressInput.focus();
            walletAddressInput.select();
          }
        };

        const saveWalletAddress = async () => {
          const nextValue = walletAddressInput.value.trim();
          const canUpdate = syncWalletCooldownState();
          if (!canUpdate) {
            walletAddressInput.setCustomValidity(walletAddressToggle.dataset.label || 'Wallet address is temporarily locked.');
            walletAddressInput.reportValidity();
            return;
          }

          walletAddressInput.setCustomValidity('');
          isSavingWalletAddress = true;
          setWalletEditMode(true);

          try {
            const response = await fetch('/api/settings/wallet-address', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
              },
              body: JSON.stringify({ withdrawalAddress: nextValue }),
            });

            const payload = (await response.json().catch(() => null)) as
              | {
                  ok?: boolean;
                  error?: string;
                  walletAddressCooldownEndsAt?: number;
                  settings?: {
                    withdrawalAddress?: string;
                    walletAddressUpdatedAt?: number | null;
                    walletAddressCooldownEndsAt?: number | null;
                    canUpdateWalletAddress?: boolean;
                  };
                }
              | null;

            if (!response.ok || !payload?.ok) {
              if (payload?.walletAddressCooldownEndsAt) {
                walletAddressCooldownEndsAt = payload.walletAddressCooldownEndsAt;
                walletAddressInput.value = currentWalletAddress;
                setWalletEditMode(false);
                syncWalletCooldownState();
              }
              throw new Error(payload?.error ?? 'Unable to save wallet address.');
            }

            currentWalletAddress = payload.settings?.withdrawalAddress ?? nextValue;
            walletAddressCooldownEndsAt = payload.settings?.walletAddressCooldownEndsAt ?? walletAddressCooldownEndsAt;
            walletAddressValue.textContent = getWalletAddressDisplayValue(currentWalletAddress);
            walletAddressInput.value = currentWalletAddress;
            setWalletEditMode(false);
          } catch (error) {
            walletAddressInput.setCustomValidity(error instanceof Error ? error.message : 'Unable to save wallet address.');
            walletAddressInput.reportValidity();
            walletAddressInput.focus();
          } finally {
            isSavingWalletAddress = false;
            syncWalletCooldownState();
          }
        };

        const cancelWalletAddressEdit = () => {
          if (isSavingWalletAddress) return;
          walletAddressInput.value = currentWalletAddress;
          walletAddressInput.setCustomValidity('');
          setWalletEditMode(false);
        };

        walletAddressToggle.addEventListener('click', async () => {
          if (isSavingWalletAddress) return;

          if (walletAddressInput.hidden && !syncWalletCooldownState()) {
            return;
          }

          if (walletAddressInput.hidden) {
            setWalletEditMode(true);
            return;
          }

          await saveWalletAddress();
        });

        walletAddressInput.addEventListener('keydown', async (event) => {
          if (event.key === 'Enter') {
            event.preventDefault();
            await saveWalletAddress();
          }

          if (event.key === 'Escape') {
            cancelWalletAddressEdit();
          }
        });

        walletAddressInput.addEventListener('input', () => {
          walletAddressInput.setCustomValidity('');
        });

        document.addEventListener('pointerdown', (event) => {
          if (walletAddressInput.hidden) return;
          if (!(event.target instanceof Node)) return;
          if (walletAddressCard.contains(event.target)) return;
          cancelWalletAddressEdit();
        });

        syncWalletCooldownState();
        walletAddressValue.textContent = getWalletAddressDisplayValue(currentWalletAddress);
      }

      const linkGenerator = document.querySelector('[data-link-generator]');
      if (linkGenerator instanceof HTMLElement) {
        const campaignNameInput = linkGenerator.querySelector('[data-link-campaign-name]');
        const campaignTagInput = linkGenerator.querySelector('[data-link-campaign-tag]');
        const generatedLinkInput = linkGenerator.querySelector('[data-generated-link]');
        const generateLinkButton = linkGenerator.querySelector('[data-generate-link]');
        const copyGeneratedLinkButton = linkGenerator.querySelector('[data-copy-generated-link]');
        const downloadQrButton = linkGenerator.querySelector('[data-download-qr]');
        const baseUrl = linkGenerator.dataset.baseUrl ?? '';
        const partnerUsername = linkGenerator.dataset.partnerUsername ?? '';
        const generateButtonLabels = {
          idle: 'Generate Link',
          pending: 'Generating...',
          complete: 'Generated',
        };

        const setGenerateButtonState = (state) => {
          if (!(generateLinkButton instanceof HTMLButtonElement)) {
            return;
          }

          generateLinkButton.textContent = generateButtonLabels[state];
          generateLinkButton.dataset.state = state;
          generateLinkButton.disabled = state !== 'idle';
        };

        const getFieldLabel = (input) => {
          if (!(input instanceof HTMLInputElement)) {
            return '';
          }

          return input.id === 'campaign-name' ? 'Campaign name' : 'Campaign tag';
        };

        const setFieldWarning = (input, isInvalid) => {
          if (!(input instanceof HTMLInputElement)) {
            return;
          }

          input.toggleAttribute('aria-invalid', isInvalid);
          input.closest('[data-link-field]')?.toggleAttribute('data-invalid', isInvalid);
        };

        const validateLinkInputs = () => {
          const requiredInputs = [campaignNameInput, campaignTagInput].filter((input) => input instanceof HTMLInputElement);
          const missingLabels = [];

          requiredInputs.forEach((input) => {
            const isEmpty = input.value.trim().length === 0;
            setFieldWarning(input, isEmpty);
            if (isEmpty) {
              missingLabels.push(getFieldLabel(input));
            }
          });

          return {
            isValid: missingLabels.length === 0,
            missingLabels,
          };
        };

        const buildGeneratedUrl = () => {
          if (
            !(campaignNameInput instanceof HTMLInputElement) ||
            !(campaignTagInput instanceof HTMLInputElement) ||
            !(generatedLinkInput instanceof HTMLInputElement)
          ) {
            return '';
          }

          const validation = validateLinkInputs();
          if (!validation.isValid) {
            generatedLinkInput.value = '';
            setGenerateButtonState('idle');
            return '';
          }

          if (!partnerUsername.trim()) {
            generatedLinkInput.value = '';
            setGenerateButtonState('idle');
            return '';
          }

          const url = new URL(baseUrl);
          const campaignTag = campaignTagInput.value.trim();
          url.searchParams.set('pid', partnerUsername.trim());
          if (campaignTag) {
            url.searchParams.set('cmp', campaignTag);
          } else {
            url.searchParams.delete('cmp');
          }
          generatedLinkInput.value = url.toString();
          return generatedLinkInput.value;
        };

        const refreshGeneratedUrlPreview = () => {
          if (!(generatedLinkInput instanceof HTMLInputElement)) {
            return;
          }

          const validation = validateLinkInputs();
          if (!validation.isValid || !partnerUsername.trim()) {
            generatedLinkInput.value = '';
            return;
          }

          const url = new URL(baseUrl);
          url.searchParams.set('pid', partnerUsername.trim());
          url.searchParams.set('cmp', campaignTagInput.value.trim());
          generatedLinkInput.value = url.toString();
        };

        const copyText = async (text) => {
          try {
            await navigator.clipboard.writeText(text);
          } catch {
            console.warn('[partner-web] Clipboard access is unavailable.');
          }
        };
        generatedLinkInput.value = '';
        setGenerateButtonState('idle');

        [campaignNameInput, campaignTagInput].forEach((input) => {
          if (input instanceof HTMLInputElement) {
            input.addEventListener('input', () => {
              setFieldWarning(input, input.value.trim().length === 0);
              refreshGeneratedUrlPreview();
              setGenerateButtonState('idle');
            });
          }
        });

        if (generateLinkButton instanceof HTMLButtonElement) {
          generateLinkButton.addEventListener('click', async () => {
            setGenerateButtonState('pending');
            await new Promise((resolve) => window.requestAnimationFrame(() => resolve(undefined)));
            const url = buildGeneratedUrl();
            if (!url) {
              return;
            }

            setGenerateButtonState('complete');
          });
        }

        if (copyGeneratedLinkButton instanceof HTMLButtonElement) {
          copyGeneratedLinkButton.addEventListener('click', async () => {
            const url = buildGeneratedUrl();
            if (!url) return;
            await copyText(url);
          });
        }

        if (downloadQrButton instanceof HTMLButtonElement) {
          downloadQrButton.addEventListener('click', async () => {
            const url = buildGeneratedUrl();
            if (!url) return;
            const qrUrl = `https://api.qrserver.com/v1/create-qr-code/?size=1024x1024&data=${encodeURIComponent(url)}`;
            try {
              const response = await fetch(qrUrl);
              if (!response.ok) throw new Error('QR request failed');
              const qrBlob = await response.blob();
              const objectUrl = URL.createObjectURL(qrBlob);
              const downloadAnchor = document.createElement('a');
              downloadAnchor.href = objectUrl;
              downloadAnchor.download = 'ramp2swap-referral-qr.png';
              document.body.appendChild(downloadAnchor);
              downloadAnchor.click();
              downloadAnchor.remove();
              URL.revokeObjectURL(objectUrl);
            } catch {
              window.open(qrUrl, '_blank', 'noopener,noreferrer');
            }
          });
        }

        document.querySelectorAll('[data-copy-text]').forEach((button) => {
          button.addEventListener('click', async () => {
            const text = button.getAttribute('data-copy-text');
            if (!text) return;
            await copyText(text);
          });
        });

        validateLinkInputs();
        refreshGeneratedUrlPreview();
      }

      const analyticsChart = document.querySelector('[data-analytics-chart]');
      if (analyticsChart instanceof HTMLElement) {
        const analyticsRangeLabel = analyticsChart.querySelector('[data-analytics-range-label]');
        const analyticsBarsContainer = analyticsChart.querySelector('[data-analytics-bars]');
        const analyticsRangeButtons = analyticsChart.querySelectorAll('[data-range-toggle]');
        const analyticsRangeData = JSON.parse(analyticsChart.dataset.analyticsRanges ?? '{}');

        const renderAnalyticsBars = (points) =>
          points
            .map(
              (point) => `
                <button
                  class="bar-button"
                  type="button"
                  data-bar-label="${point.label}"
                  data-bar-clicks="${point.clicks}"
                  data-bar-conversion="${point.conversionRate}"
                  aria-label="${point.label}: ${point.clicks} clicks, ${point.conversionRate} conversion rate"
                  style="height: ${point.height}%"
                >
                  <span class="bar-fill"></span>
                </button>
              `,
            )
            .join('');

        const setAnalyticsRange = (rangeKey) => {
          const range = analyticsRangeData[rangeKey];
          if (!range) return;

          analyticsRangeButtons.forEach((button) => {
            button.classList.toggle('analytics-range-button-active', button.getAttribute('data-range-toggle') === rangeKey);
          });

          if (analyticsRangeLabel instanceof HTMLElement) {
            analyticsRangeLabel.textContent = range.timeRangeLabel;
          }

          if (analyticsBarsContainer instanceof HTMLElement) {
            analyticsBarsContainer.innerHTML = renderAnalyticsBars(range.points);
          }
        };

        analyticsRangeButtons.forEach((button) => {
          button.addEventListener('click', () => {
            const rangeKey = button.getAttribute('data-range-toggle');
            if (!rangeKey) return;
            setAnalyticsRange(rangeKey);
          });
        });
      }
    </script>
  </body>
</html>
