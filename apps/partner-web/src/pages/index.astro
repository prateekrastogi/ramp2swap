---
import '../styles/design-system.css';
import { payoutDisplaySettings } from '../data/settings-display';
import { getPartnerApiBaseUrl, getPartnerLinkBaseUrl } from '../lib/runtime-env';
import { loadTransactionFeed, type TransactionFeedItem } from '../data/transaction-feed';

type PartnerSessionPayload = {
  ok?: boolean;
  email?: string;
  uid?: string;
  settings?: {
    username?: string;
    withdrawalAddress?: string;
    walletAddressUpdatedAt?: number | null;
    walletAddressCooldownEndsAt?: number | null;
    canUpdateWalletAddress?: boolean;
  };
};

type PartnerLink = {
  id: string;
  campaignName: string;
  campaignTag: string;
  generatedUrl: string;
  createdAt: number;
  updatedAt: number;
};

type AnalyticsRangeKey = '10D' | '30D' | '90D';

type AnalyticsChartPoint = {
  label: string;
  clicks: number;
  conversionRate: string;
  height: number;
};

type AnalyticsSummary = {
  timeRangeLabel: string;
  points: AnalyticsChartPoint[];
};

type AnalyticsBreakdownItem = {
  label: string;
  pct: number;
  clicks: number;
  conversions: number;
  conversionRate: string;
};

type PartnerAnalyticsPayload = {
  ok?: boolean;
  username?: string;
  ranges?: Partial<Record<AnalyticsRangeKey, AnalyticsSummary>>;
  topLinks?: Partial<Record<AnalyticsRangeKey, AnalyticsBreakdownItem[]>>;
  geography?: Partial<Record<AnalyticsRangeKey, AnalyticsBreakdownItem[]>>;
};

type PartnerEarningsPayload = {
  ok?: boolean;
  username?: string;
  currentCommissionBps?: number;
  currentBalance?: string;
  pendingBalance?: string;
  availableBalance?: string;
  totalEarnings?: string;
};

type PayoutHistoryEntry = {
  amount: string;
  status: 'paid' | 'pending';
  destination: string;
  meta: string;
  date: string;
};

type PartnerSettlementsPayload = {
  ok?: boolean;
  username?: string;
  records?: PayoutHistoryEntry[];
};

type OverviewMetricShell = {
  id: string;
  label: string;
  emptyMessage: string;
  accent?: 'mint';
};

type OverviewMetricSummary = {
  id: string;
  label: string;
  value: string;
  detail: string;
  delta: string;
  accent?: 'mint';
};

type PartnerOverviewPayload = {
  ok?: boolean;
  username?: string;
  metrics?: OverviewMetricSummary[];
};

const sessionToken = Astro.cookies.get('partner_session')?.value ?? '';
const partnerApiBaseUrl = await getPartnerApiBaseUrl();
const partnerLinkBaseUrl = await getPartnerLinkBaseUrl();

const partnerSettings = {
  email: 'partners@ramp2swap.com',
  uid: '',
  username: 'prime-vault',
  withdrawalAddress: '',
  walletAddressUpdatedAt: null as number | null,
  walletAddressCooldownEndsAt: null as number | null,
  canUpdateWalletAddress: true,
};
let savedPartnerLinks: PartnerLink[] = [];
let transactionFeedItems: TransactionFeedItem[] = [];
let analyticsSummaries: Partial<Record<AnalyticsRangeKey, AnalyticsSummary>> = {};
let topPerformingLinksByRange: Partial<Record<AnalyticsRangeKey, AnalyticsBreakdownItem[]>> = {};
let geographicBreakdownByRange: Partial<Record<AnalyticsRangeKey, AnalyticsBreakdownItem[]>> = {};
let earningsSummary = {
  currentCommissionBps: 15,
  currentBalance: '$0.00',
  pendingBalance: '$0.00',
  availableBalance: '$0.00',
  totalEarnings: '$0.00',
};
let overviewMetrics: OverviewMetricSummary[] = [];
let payoutHistoryEntries: PayoutHistoryEntry[] = [];

const overviewMetricShells: OverviewMetricShell[] = [
  {
    id: 'total-clicks',
    label: 'Total Clicks',
    emptyMessage: 'Click totals for the last 30 days across all referral links will appear here.',
  },
  {
    id: 'conversions',
    label: 'Conversions',
    emptyMessage: 'Completed attributed ramp transactions for the last 30 days will appear here.',
  },
  {
    id: 'volume-driven',
    label: 'Volume Driven',
    emptyMessage: 'Total partner-driven fiat to crypto volume for the last 30 days will appear here.',
  },
  {
    id: 'commission-balance',
    label: 'Commission Balance',
    emptyMessage: 'Available and pending commission earnings will appear here.',
    accent: 'mint',
  },
];

const formatCompactDate = (timestamp: number) => {
  const date = new Date(timestamp);
  const year = String(date.getFullYear()).slice(-2);
  const month = String(date.getMonth() + 1).padStart(2, '0');
  const day = String(date.getDate()).padStart(2, '0');
  return `${year}/${month}/${day}`;
};

if (sessionToken && partnerApiBaseUrl) {
  try {
    const sessionResponse = await fetch(`${partnerApiBaseUrl}/auth/session`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({ sessionToken }),
    });

    const payload = (await sessionResponse.json().catch(() => null)) as PartnerSessionPayload | null;
    if (sessionResponse.ok && payload?.ok) {
      partnerSettings.email = payload.email ?? partnerSettings.email;
      partnerSettings.uid = payload.uid ?? partnerSettings.uid;
      partnerSettings.username = payload.settings?.username ?? partnerSettings.username;
      partnerSettings.withdrawalAddress = payload.settings?.withdrawalAddress ?? partnerSettings.withdrawalAddress;
      partnerSettings.walletAddressUpdatedAt = payload.settings?.walletAddressUpdatedAt ?? partnerSettings.walletAddressUpdatedAt;
      partnerSettings.walletAddressCooldownEndsAt =
        payload.settings?.walletAddressCooldownEndsAt ?? partnerSettings.walletAddressCooldownEndsAt;
      partnerSettings.canUpdateWalletAddress = payload.settings?.canUpdateWalletAddress ?? partnerSettings.canUpdateWalletAddress;
    }

    const [linksResponse, loadedTransactionFeed, analyticsResponse, earningsResponse, overviewResponse, settlementsResponse] = await Promise.all([
      fetch(`${partnerApiBaseUrl}/link`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ sessionToken }),
      }),
      loadTransactionFeed({
        partnerApiBaseUrl,
        sessionToken,
        username: partnerSettings.username,
      }),
      fetch(`${partnerApiBaseUrl}/analytic`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ sessionToken }),
      }),
      fetch(`${partnerApiBaseUrl}/earning`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ sessionToken }),
      }),
      fetch(`${partnerApiBaseUrl}/overview`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ sessionToken }),
      }),
      fetch(`${partnerApiBaseUrl}/settlement`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ sessionToken }),
      }),
    ]);

    const linksPayload = (await linksResponse.json().catch(() => null)) as { ok?: boolean; links?: PartnerLink[] } | null;
    if (linksResponse.ok && linksPayload?.ok && Array.isArray(linksPayload.links)) {
      savedPartnerLinks = linksPayload.links;
    }

    const analyticsPayload = (await analyticsResponse.json().catch(() => null)) as PartnerAnalyticsPayload | null;
    if (analyticsResponse.ok && analyticsPayload?.ok) {
      analyticsSummaries = analyticsPayload.ranges ?? analyticsSummaries;
      topPerformingLinksByRange =
        analyticsPayload.topLinks && typeof analyticsPayload.topLinks === 'object'
          ? analyticsPayload.topLinks
          : topPerformingLinksByRange;
      geographicBreakdownByRange =
        analyticsPayload.geography && typeof analyticsPayload.geography === 'object'
          ? analyticsPayload.geography
          : geographicBreakdownByRange;
    }

    const earningsPayload = (await earningsResponse.json().catch(() => null)) as PartnerEarningsPayload | null;
    if (earningsResponse.ok && earningsPayload?.ok) {
      earningsSummary = {
        currentCommissionBps:
          typeof earningsPayload.currentCommissionBps === 'number' &&
          Number.isFinite(earningsPayload.currentCommissionBps)
            ? earningsPayload.currentCommissionBps
            : earningsSummary.currentCommissionBps,
        currentBalance: earningsPayload.currentBalance ?? earningsSummary.currentBalance,
        pendingBalance: earningsPayload.pendingBalance ?? earningsSummary.pendingBalance,
        availableBalance: earningsPayload.availableBalance ?? earningsSummary.availableBalance,
        totalEarnings: earningsPayload.totalEarnings ?? earningsSummary.totalEarnings,
      };
    }

    const overviewPayload = (await overviewResponse.json().catch(() => null)) as PartnerOverviewPayload | null;
    if (overviewResponse.ok && overviewPayload?.ok && Array.isArray(overviewPayload.metrics)) {
      overviewMetrics = overviewPayload.metrics;
    }

    const settlementsPayload =
      (await settlementsResponse.json().catch(() => null)) as PartnerSettlementsPayload | null;
    if (settlementsResponse.ok && settlementsPayload?.ok && Array.isArray(settlementsPayload.records)) {
      payoutHistoryEntries = settlementsPayload.records;
    }

    transactionFeedItems = loadedTransactionFeed;
  } catch (error) {
    console.warn('[partner-web] failed to load partner settings', error);
  }
}

const EMPTY_WALLET_ADDRESS_DISPLAY = 'Editable once every 7 days';
const walletAddressDisplayValue =
  partnerSettings.withdrawalAddress === '' ? EMPTY_WALLET_ADDRESS_DISPLAY : partnerSettings.withdrawalAddress;
const generatedLinkPlaceholder =
  partnerLinkBaseUrl && partnerSettings.username
    ? `${partnerLinkBaseUrl}?pid=${partnerSettings.username}&cmp=satoshi-nakamoto`
    : 'Generated referral link will appear here';

const renderAnalyticsBars = (points: AnalyticsChartPoint[]) =>
  points
    .map(
      (point) => `
        <button
          class="bar-button"
          type="button"
          data-bar-label="${point.label}"
          data-bar-clicks="${point.clicks}"
          data-bar-conversion="${point.conversionRate}"
          aria-label="${point.label}: ${point.clicks} clicks, ${point.conversionRate} conversion rate"
          style="height: ${point.height}%"
        >
          <span class="bar-fill"></span>
        </button>
      `,
    )
    .join('');

const escapeAnalyticsHtml = (value: string | number) =>
  String(value)
    .replaceAll('&', '&amp;')
    .replaceAll('<', '&lt;')
    .replaceAll('>', '&gt;')
    .replaceAll('"', '&quot;')
    .replaceAll("'", '&#39;');

const formatAnalyticsPct = (pct: number) => `${Number.isInteger(pct) ? pct.toFixed(0) : pct.toFixed(1)}%`;

const renderAnalyticsBreakdownRows = (items: AnalyticsBreakdownItem[]) =>
  items
    .map(
      (item) => `
        <div class="progress-row">
          <button
            class="analytics-breakdown-button"
            type="button"
            data-breakdown-label="${escapeAnalyticsHtml(item.label)}"
            data-breakdown-clicks="${item.clicks}"
            data-breakdown-conversions="${item.conversions}"
            data-breakdown-conversion="${escapeAnalyticsHtml(item.conversionRate)}"
            data-breakdown-percent="${formatAnalyticsPct(item.pct)}"
            aria-label="${escapeAnalyticsHtml(item.label)}: ${item.clicks} clicks, ${item.conversions} conversions, ${escapeAnalyticsHtml(item.conversionRate)} conversion rate, ${formatAnalyticsPct(item.pct)} share"
          >
            <div class="row-12 analytics-progress-head">
              <span class="body-small">${escapeAnalyticsHtml(item.label)}</span>
              <span class="data-small">${formatAnalyticsPct(item.pct)}</span>
            </div>
            <div class="progress-track">
              <div class="progress-fill" style="width: ${item.pct}%;"></div>
            </div>
          </button>
        </div>
      `,
    )
    .join('');

const analyticsRangeOrder: AnalyticsRangeKey[] = ['30D', '10D', '90D'];
const analyticsRangeFallbackKey =
  analyticsRangeOrder.find((rangeKey) => analyticsSummaries[rangeKey] || topPerformingLinksByRange[rangeKey] || geographicBreakdownByRange[rangeKey]) ?? '30D';
const analyticsChartDefaultRange =
  analyticsRangeOrder
    .map((rangeKey) => analyticsSummaries[rangeKey] ?? null)
    .find((range) => range !== null && range.points.some((point) => point.clicks > 0)) ??
  analyticsSummaries['30D'] ??
  analyticsSummaries['10D'] ??
  analyticsSummaries['90D'] ??
  null;
const analyticsHasChartData = analyticsChartDefaultRange !== null && analyticsChartDefaultRange.points.some((point) => point.clicks > 0);
const analyticsTopLinksDefaultRangeKey =
  analyticsRangeOrder.find((rangeKey) => (topPerformingLinksByRange[rangeKey] ?? []).length > 0) ?? analyticsRangeFallbackKey;
const analyticsGeoDefaultRangeKey =
  analyticsRangeOrder.find((rangeKey) => (geographicBreakdownByRange[rangeKey] ?? []).length > 0) ?? analyticsRangeFallbackKey;
const analyticsTopLinksDefaultItems = topPerformingLinksByRange[analyticsTopLinksDefaultRangeKey] ?? [];
const analyticsGeoDefaultItems = geographicBreakdownByRange[analyticsGeoDefaultRangeKey] ?? [];
const analyticsHasTopLinks = analyticsTopLinksDefaultItems.length > 0;
const analyticsHasGeography = analyticsGeoDefaultItems.length > 0;
const overviewMetricsById = new Map(overviewMetrics.map((metric) => [metric.id, metric]));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Ramp2Swap partner portal" />
    <title>Partner Portal | Ramp2Swap</title>
    <link rel="icon" type="image/png" href="/logo.png" />
  </head>
  <body class="page">
    <input id="sidebar-collapse" class="sidebar-control" type="checkbox" />
    <input id="sidebar-pin" class="sidebar-control" type="checkbox" />
    <input id="sidebar-mobile" class="sidebar-control" type="checkbox" />

    <div class="ambient-layer" aria-hidden="true">
      <div class="ambient-orb ambient-orb--mint-top"></div>
      <div class="ambient-orb ambient-orb--blue-bottom"></div>
      <div class="ambient-orb ambient-orb--mint-center"></div>
    </div>

    <header class="mobile-topbar content-layer">
      <button class="hamburger-btn" id="mobile-sidebar-toggle" type="button" aria-label="Open navigation">
        <svg class="hamburger-icon" viewBox="0 0 24 24" aria-hidden="true">
          <line class="hamburger-line hamburger-line-top" x1="5" y1="7" x2="19" y2="7"></line>
          <line class="hamburger-line hamburger-line-mid" x1="5" y1="12" x2="19" y2="12"></line>
          <line class="hamburger-line hamburger-line-bottom" x1="5" y1="17" x2="19" y2="17"></line>
        </svg>
      </button>
      <button class="mobile-topbar-logo-toggle" id="mobile-logo-toggle" type="button" aria-label="Toggle navigation">
        <img class="logo-mark mobile-topbar-mark" src="/logo.png" alt="Ramp2Swap mark" />
      </button>
    </header>

    <label for="sidebar-mobile" class="mobile-overlay" aria-hidden="true"></label>

    <div class="dashboard-toast" data-link-toast hidden>
      <div class="dashboard-toast-body">
        <span class="dashboard-toast-icon" data-link-toast-icon aria-hidden="true">
          <svg viewBox="0 0 24 24" focusable="false">
            <path d="M12 4 3.5 19h17L12 4Z"></path>
            <path d="M12 9v5"></path>
            <path d="M12 17h.01"></path>
          </svg>
        </span>
        <div class="stack-4">
          <p class="heading-card dashboard-toast-title" data-link-toast-title></p>
          <p class="body-small dashboard-toast-copy" data-link-toast-copy></p>
        </div>
      </div>
    </div>

    <main class="dashboard-shell content-layer">
      <aside class="sidebar glass glass-tier-4-nav on-glass">
        <button class="sidebar-brand" id="sidebar-brand-toggle" type="button" aria-label="Toggle navigation">
          <img class="logo-horizontal sidebar-logo-horizontal" src="/logo_horizontal.png" alt="Ramp2Swap" />
          <img class="logo-mark sidebar-logo-mark" src="/logo.png" alt="Ramp2Swap mark" />
        </button>

        <nav class="sidebar-nav" aria-label="Primary navigation">
          <section class="nav-section">
            <a class="nav-item nav-item-active" href="#overview" data-label="Overview" data-view-target="overview"><span class="nav-icon">◫</span><span class="nav-text">Overview</span></a>
            <a class="nav-item" href="#link-generator" data-label="Link Generator" data-view-target="link-generator"><span class="nav-icon nav-icon-text">⛓︎</span><span class="nav-text">Link Generator</span></a>
            <a class="nav-item" href="#transaction-feed" data-label="Transaction Feed" data-view-target="transaction-feed"><span class="nav-icon">⇄</span><span class="nav-text">Transaction Feed</span></a>
            <a class="nav-item" href="#earnings-payouts" data-label="Earnings & Payouts" data-view-target="earnings-payouts"><span class="nav-icon">$</span><span class="nav-text">Earnings & Payouts</span></a>
            <a class="nav-item" href="#analytics" data-label="Analytics" data-view-target="analytics"><span class="nav-icon">◔</span><span class="nav-text">Analytics</span></a>
          </section>
        </nav>

        <div class="sidebar-bottom">
          <a class="nav-item" href="#settings" data-label="Settings" data-view-target="settings"><span class="nav-icon">⚙</span><span class="nav-text">Settings</span></a>
          <a class="nav-item" href="mailto:help@ramp2swap.com" data-label="Help"><span class="nav-icon">i</span><span class="nav-text">Help</span></a>

          <div class="sidebar-profile" data-label="Profile">
            <img class="sidebar-avatar" data-sidebar-avatar alt="Partner identicon" />
            <span class="profile-copy">
              <span class="profile-name" data-profile-name>{partnerSettings.username}</span>
              <span class="profile-role">PRO PLAN</span>
            </span>
            <button class="sidebar-logout" type="button" aria-label="Logout" data-label="Logout">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M14 7l5 5-5 5"></path>
                <path d="M19 12H9"></path>
                <path d="M12 5H6a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h6"></path>
              </svg>
            </button>
          </div>
        </div>
      </aside>

      <section class="dashboard-content" aria-label="Dashboard content area">
        <div class="dashboard-main">
          <section id="overview" class="overview-shell" data-dashboard-view="overview">
            <div class="dashboard-section-header">
              <div class="stack-12">
                <p class="ui-label">Overview</p>
                <h1 class="heading-card heading-section dashboard-section-title">Partner Performance Snapshot</h1>
                <p class="body dashboard-section-copy">
                  Core referral performance metrics for the rolling 30-day reporting window.
                </p>
              </div>
            </div>

            <div class="performance-metrics-grid">
              {overviewMetricShells.map((metric) => {
                const overviewMetric = overviewMetricsById.get(metric.id);

                return (
                <article class={`card performance-metric-card ${overviewMetric ? '' : 'performance-metric-card-empty'} glass glass-interactive ${metric.accent === 'mint' ? 'glass-tier-2 glass-highlight-soft performance-metric-card-highlight' : 'glass-tier-1'} on-glass`}>
                  {overviewMetric ? (
                    <>
                      <div class="performance-metric-card-top">
                        <p class="ui-label">{overviewMetric.label}</p>
                        <span class={`performance-metric-delta ${metric.accent === 'mint' ? 'performance-metric-delta-accent' : ''}`}>
                          {overviewMetric.delta}
                        </span>
                      </div>
                      <p class="data-large performance-metric-value">{overviewMetric.value}</p>
                      <p class="body-small performance-metric-detail">{overviewMetric.detail}</p>
                    </>
                  ) : (
                    <>
                      <div class="performance-metric-card-top">
                        <p class="ui-label">{metric.label}</p>
                      </div>
                      <div class="performance-metric-empty-state">
                        <p class="body-small performance-metric-empty-copy empty-state-copy">
                          {metric.emptyMessage}
                        </p>
                      </div>
                    </>
                  )}
                </article>
                );
              })}
            </div>
          </section>

          <section id="link-generator" class="link-generator-shell" data-dashboard-view="link-generator" hidden>
            <div class="dashboard-section-header">
              <div class="stack-12">
                <p class="ui-label">Link Generator</p>
                <h2 class="heading-card heading-section dashboard-section-title">Generate Referral Links</h2>
                <p class="body dashboard-section-copy">
                  Create partner-specific referral URLs, append campaign tags, and manage active links.
                </p>
              </div>
            </div>

            <div class="link-generator-grid">
              <article class="card glass glass-tier-2 glass-mint glass-interactive on-glass link-generator-card">
                <div class="widget-header">
                  <p class="heading-card">Primary Link Builder</p>
                  <span class="badge-active">Core Flow</span>
                </div>

                <div
                  class="link-form-grid"
                  data-link-generator
                  data-base-url={partnerLinkBaseUrl}
                  data-partner-username={partnerSettings.username}
                >
                  <div class="stack-12">
                    <label class="ui-label" for="campaign-name">CAMPAIGN NAME</label>
                    <div class="link-input-shell" data-link-field>
                      <input
                        id="campaign-name"
                        class="input input-glass"
                        data-link-campaign-name
                        placeholder="Main_Yield_Launch_V1"
                      />
                      <span class="link-input-warning" data-link-warning-icon aria-hidden="true">
                        <svg viewBox="0 0 24 24" focusable="false">
                          <path d="M12 4 3.5 19h17L12 4Z"></path>
                          <path d="M12 9v5"></path>
                          <path d="M12 17h.01"></path>
                        </svg>
                      </span>
                    </div>
                  </div>

                  <div class="stack-12">
                    <label class="ui-label" for="campaign-tag">Campaign Tag</label>
                    <div class="link-input-shell" data-link-field>
                      <input
                        id="campaign-tag"
                        class="input input-glass"
                        data-link-campaign-tag
                        placeholder="satoshi-nakamoto"
                      />
                      <span class="link-input-warning" data-link-warning-icon aria-hidden="true">
                        <svg viewBox="0 0 24 24" focusable="false">
                          <path d="M12 4 3.5 19h17L12 4Z"></path>
                          <path d="M12 9v5"></path>
                          <path d="M12 17h.01"></path>
                        </svg>
                      </span>
                    </div>
                  </div>

                  <div class="stack-12 link-output-block">
                    <label class="ui-label" for="generated-link">Generated Referral URL</label>
                    <div class="link-output-shell">
                      <input
                        id="generated-link"
                        class="input input-glass link-output-input"
                        data-generated-link
                        value=""
                        placeholder={generatedLinkPlaceholder}
                        readonly
                      />
                      <div class="link-output-actions">
                        <button class="btn-primary btn-glass" type="button" data-generate-link>Generate Link</button>
                      </div>
                    </div>
                  </div>
                </div>

              </article>

              <article class="card glass glass-tier-1 glass-interactive on-glass link-campaigns-card">
                <div class="widget-header">
                  <p class="heading-card">Saved Campaign Links</p>
                  <span class="chip" data-link-count>{savedPartnerLinks.length} active</span>
                </div>

                <div class="link-campaign-list" data-saved-links-list>
                  {savedPartnerLinks.length > 0 ? (
                    savedPartnerLinks.map((link) => (
                    <article class="link-campaign-row" data-link-id={link.id}>
                      <div class="link-campaign-head">
                        <div class="stack-8">
                          <p class="heading-card">{link.campaignName}</p>
                          <p class="data-small">{link.campaignTag}</p>
                        </div>
                        <span class="link-inline-stat">{formatCompactDate(link.createdAt)}</span>
                      </div>

                      <p class="link-url">{link.generatedUrl}</p>

                      <div class="link-campaign-meta">
                        <button class="link-delete-button" type="button" data-delete-link-id={link.id} aria-label="Delete generated link">
                          <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M4 7h16"></path>
                            <path d="M10 11v6"></path>
                            <path d="M14 11v6"></path>
                            <path d="M6 7l1 12h10l1-12"></path>
                            <path d="M9 7V4h6v3"></path>
                          </svg>
                        </button>
                        <div class="link-row-actions">
                          <button class="link-action-button" type="button" data-download-qr-link={link.generatedUrl} aria-label="Download QR code">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                              <path d="M4 4h6v6H4z"></path>
                              <path d="M14 4h6v6h-6z"></path>
                              <path d="M4 14h6v6H4z"></path>
                              <path d="M14 14h2"></path>
                              <path d="M18 14h2v2"></path>
                              <path d="M14 18h2v2h-2z"></path>
                              <path d="M18 18h2"></path>
                            </svg>
                          </button>
                          <button class="link-action-button" type="button" data-copy-text={link.generatedUrl} aria-label="Copy generated link">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                              <rect x="9" y="9" width="10" height="10" rx="2"></rect>
                              <path d="M6 15H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v1"></path>
                            </svg>
                          </button>
                        </div>
                      </div>
                    </article>
                  ))
                  ) : (
