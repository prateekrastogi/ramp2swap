---
import '../styles/design-system.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Ramp2Swap partner portal" />
    <title>Ramp2Swap Partner Portal</title>
    <link rel="icon" type="image/png" href="/logo.png" />
  </head>
  <body class="page">
    <main class="container">
      <section class="surface section" style="display: grid; place-items: center; min-height: 60vh; text-align: center;">
        <img src="/logo_horizontal.png" alt="Ramp2Swap" style="max-width: 360px; width: 100%; height: auto;" />
        <p class="body" style="margin-top: 12px;">Partner Portal</p>
        <a class="btn-primary" href="/design-system" style="margin-top: 16px;">View Design System</a>
      </section>
    </main>
  </body>
</html>
