    </main>

    <script>
      const collapseControl = document.getElementById('sidebar-collapse');
      if (collapseControl instanceof HTMLInputElement && window.matchMedia('(min-width: 1280px)').matches) {
        collapseControl.checked = false;
      }

      const mobileSidebarToggle = document.getElementById('mobile-sidebar-toggle');
      const mobileLogoToggle = document.getElementById('mobile-logo-toggle');
      const sidebarBrandToggle = document.getElementById('sidebar-brand-toggle');
      const sidebarLogoutButton = document.querySelector('.sidebar-logout');
      const sidebarElement = document.querySelector('.sidebar');
      const mobileTopbar = document.querySelector('.mobile-topbar');
      const mobileControl = document.getElementById('sidebar-mobile');
      const pinControl = document.getElementById('sidebar-pin');
      const navViewTriggers = document.querySelectorAll('[data-view-target]');
      const dashboardViews = document.querySelectorAll('[data-dashboard-view]');
      const profileNameNode = document.querySelector('[data-profile-name]');
      const sidebarAvatar = document.querySelector('[data-sidebar-avatar]');
      const settingsViewTriggers = document.querySelectorAll('[data-settings-target]');
      const settingsPanels = document.querySelectorAll('[data-settings-panel]');

      if (profileNameNode instanceof HTMLElement && sidebarAvatar instanceof HTMLImageElement) {
        const usernameSeed = profileNameNode.textContent?.trim() || 'prime-vault';
        sidebarAvatar.src = `https://api.dicebear.com/9.x/identicon/svg?seed=${encodeURIComponent(usernameSeed)}`;
      }

      if (
        sidebarBrandToggle instanceof HTMLButtonElement &&
        mobileControl instanceof HTMLInputElement &&
        pinControl instanceof HTMLInputElement
      ) {
        sidebarBrandToggle.addEventListener('click', () => {
          if (window.matchMedia('(max-width: 767px)').matches) {
            mobileControl.checked = !mobileControl.checked;
            return;
          }

          if (window.matchMedia('(min-width: 768px) and (max-width: 1279px)').matches) {
            pinControl.checked = !pinControl.checked;
            return;
          }

          if (collapseControl instanceof HTMLInputElement) {
            collapseControl.checked = !collapseControl.checked;
          }
        });
      }

      if (mobileSidebarToggle instanceof HTMLButtonElement && mobileControl instanceof HTMLInputElement) {
        mobileSidebarToggle.addEventListener('click', (event) => {
          event.stopPropagation();
          mobileControl.checked = !mobileControl.checked;
        });
      }

      if (mobileLogoToggle instanceof HTMLButtonElement && mobileControl instanceof HTMLInputElement) {
        mobileLogoToggle.addEventListener('click', (event) => {
          event.stopPropagation();
          mobileControl.checked = !mobileControl.checked;
        });
      }

      if (sidebarLogoutButton instanceof HTMLButtonElement) {
        sidebarLogoutButton.addEventListener('click', async () => {
          sidebarLogoutButton.disabled = true;

          try {
            await fetch('/api/auth/logout', {
              method: 'POST',
              credentials: 'same-origin',
            });
          } finally {
            window.location.replace('/login');
          }
        });
      }

      document.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof Node) || !(sidebarElement instanceof HTMLElement)) {
          return;
        }

        const clickedInsideSidebar = sidebarElement.contains(target);
        const clickedMobileTopbar = mobileTopbar instanceof HTMLElement && mobileTopbar.contains(target);

        if (
          pinControl instanceof HTMLInputElement &&
          pinControl.checked &&
          window.matchMedia('(min-width: 768px) and (max-width: 1279px)').matches &&
          !clickedInsideSidebar
        ) {
          pinControl.checked = false;
        }

        if (
          mobileControl instanceof HTMLInputElement &&
          mobileControl.checked &&
          window.matchMedia('(max-width: 767px)').matches &&
          !clickedInsideSidebar &&
          !clickedMobileTopbar
        ) {
          mobileControl.checked = false;
        }
      });

      if (navViewTriggers.length > 0 && dashboardViews.length > 0) {
        const setActiveView = (viewName) => {
          navViewTriggers.forEach((trigger) => {
            const isActive = trigger.getAttribute('data-view-target') === viewName;
            trigger.classList.toggle('nav-item-active', isActive);
          });

          dashboardViews.forEach((view) => {
            view.hidden = view.getAttribute('data-dashboard-view') !== viewName;
          });

          if (mobileControl instanceof HTMLInputElement && window.matchMedia('(max-width: 767px)').matches) {
            mobileControl.checked = false;
          }
        };

        navViewTriggers.forEach((trigger) => {
          trigger.addEventListener('click', (event) => {
            const target = trigger.getAttribute('data-view-target');
            if (!target) return;
            event.preventDefault();
            setActiveView(target);
          });
        });
      }

      if (settingsViewTriggers.length > 0 && settingsPanels.length > 0) {
        const setActiveSettingsPanel = (panelName) => {
          settingsViewTriggers.forEach((trigger) => {
            const isActive = trigger.getAttribute('data-settings-target') === panelName;
            trigger.classList.toggle('settings-nav-button-active', isActive);
          });

          settingsPanels.forEach((panel) => {
            panel.hidden = panel.getAttribute('data-settings-panel') !== panelName;
          });
        };

        settingsViewTriggers.forEach((trigger) => {
          trigger.addEventListener('click', () => {
            const target = trigger.getAttribute('data-settings-target');
            if (!target) return;
            setActiveSettingsPanel(target);
          });
        });
      }

      const walletAddressCard = document.querySelector('[data-wallet-address-toggle]')?.closest('.settings-field-card');
      const walletAddressToggle = document.querySelector('[data-wallet-address-toggle]');
      const walletAddressValue = document.querySelector('[data-wallet-address-value]');
      const walletAddressInput = document.querySelector('[data-wallet-address-input]');
      const walletAddressShell = document.querySelector('.settings-wallet-shell');

      if (
        walletAddressCard instanceof HTMLElement &&
        walletAddressToggle instanceof HTMLButtonElement &&
        walletAddressValue instanceof HTMLElement &&
        walletAddressInput instanceof HTMLInputElement
      ) {
        const emptyWalletAddressDisplay = 'Editable once every 7 days';
        const editIcon = `
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4 20h4l10-10-4-4L4 16v4Z"></path>
            <path d="M13 7l4 4"></path>
          </svg>
        `;
        const saveIcon = `
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="m5 12 4 4L19 6"></path>
          </svg>
        `;

        let currentWalletAddress = walletAddressInput.value.trim();
        let isSavingWalletAddress = false;
        let walletAddressCooldownEndsAt = Number(walletAddressToggle.dataset.walletAddressCooldownEndsAt || '') || null;
        let cooldownTimer = null;

        const getWalletAddressDisplayValue = (value) => (value === '' ? emptyWalletAddressDisplay : value);
        const syncWalletFilledState = () => {
          if (!(walletAddressShell instanceof HTMLElement)) {
            return;
          }

          walletAddressShell.dataset.walletFilled = currentWalletAddress ? 'true' : 'false';
        };

        const formatRelativeDuration = (milliseconds) => {
          const totalMinutes = Math.max(1, Math.ceil(milliseconds / (1000 * 60)));
          const days = Math.floor(totalMinutes / (24 * 60));
          const hours = Math.floor((totalMinutes % (24 * 60)) / 60);
          const minutes = totalMinutes % 60;

          return `${days}D ${hours}H ${minutes}M`;
        };

        const getWalletButtonLabel = (isEditing, canUpdate) => {
          if (isEditing) {
            return 'Save wallet address';
          }

          if (!canUpdate && typeof walletAddressCooldownEndsAt === 'number' && walletAddressCooldownEndsAt > Date.now()) {
            return `Editable in ${formatRelativeDuration(walletAddressCooldownEndsAt - Date.now())}`;
          }

          return 'Edit wallet address';
        };

        const syncWalletCooldownState = () => {
          const now = Date.now();
          const canUpdate = typeof walletAddressCooldownEndsAt !== 'number' || walletAddressCooldownEndsAt <= now;
          const isEditing = !walletAddressInput.hidden;
          const buttonLabel = getWalletButtonLabel(isEditing, canUpdate);

          walletAddressToggle.dataset.walletAddressCanUpdate = canUpdate ? 'true' : 'false';
          walletAddressToggle.dataset.walletAddressCooldownEndsAt = walletAddressCooldownEndsAt ? String(walletAddressCooldownEndsAt) : '';
          walletAddressToggle.dataset.label = buttonLabel;
          walletAddressToggle.setAttribute('aria-label', buttonLabel);

          if (isSavingWalletAddress) {
            walletAddressToggle.disabled = true;
            walletAddressInput.disabled = true;
          } else {
            walletAddressToggle.disabled = false;
            walletAddressInput.disabled = !canUpdate && !isEditing;
          }

          if (cooldownTimer !== null) {
            window.clearTimeout(cooldownTimer);
            cooldownTimer = null;
          }

          if (!canUpdate && typeof walletAddressCooldownEndsAt === 'number') {
            const millisecondsUntilNextMinute = 60_000 - (now % 60_000);
            const nextRefreshDelay = Math.min(
              Math.max(millisecondsUntilNextMinute, 1_000),
              Math.max(walletAddressCooldownEndsAt - now, 1_000),
            );
            cooldownTimer = window.setTimeout(syncWalletCooldownState, nextRefreshDelay);
          }

          return canUpdate;
        };

        const setWalletEditMode = (isEditing) => {
          walletAddressValue.hidden = isEditing;
          walletAddressInput.hidden = !isEditing;
          walletAddressToggle.innerHTML = isEditing ? saveIcon : editIcon;
          syncWalletCooldownState();

          if (isEditing) {
            walletAddressInput.placeholder = emptyWalletAddressDisplay;
            walletAddressInput.value = currentWalletAddress;
          } else {
            walletAddressValue.textContent = getWalletAddressDisplayValue(currentWalletAddress);
          }

          syncWalletFilledState();

          if (isEditing) {
            walletAddressInput.focus();
            walletAddressInput.select();
          }
        };

        const saveWalletAddress = async () => {
          const nextValue = walletAddressInput.value.trim();
          const canUpdate = syncWalletCooldownState();
          if (!canUpdate) {
            walletAddressInput.setCustomValidity(walletAddressToggle.dataset.label || 'Wallet address is temporarily locked.');
            walletAddressInput.reportValidity();
            return;
          }

          walletAddressInput.setCustomValidity('');
          isSavingWalletAddress = true;
          setWalletEditMode(true);

          try {
            const response = await fetch('/api/setting/wallet-address', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
              },
              body: JSON.stringify({ withdrawalAddress: nextValue }),
            });

            const payload = (await response.json().catch(() => null)) as
              | {
                  ok?: boolean;
                  error?: string;
                  walletAddressCooldownEndsAt?: number;
                  settings?: {
                    withdrawalAddress?: string;
                    walletAddressUpdatedAt?: number | null;
                    walletAddressCooldownEndsAt?: number | null;
                    canUpdateWalletAddress?: boolean;
                  };
                }
              | null;

            if (!response.ok || !payload?.ok) {
              if (payload?.walletAddressCooldownEndsAt) {
                walletAddressCooldownEndsAt = payload.walletAddressCooldownEndsAt;
                walletAddressInput.value = currentWalletAddress;
                setWalletEditMode(false);
                syncWalletCooldownState();
              }
              throw new Error(payload?.error ?? 'Unable to save wallet address.');
            }

            currentWalletAddress = payload.settings?.withdrawalAddress ?? nextValue;
            walletAddressCooldownEndsAt = payload.settings?.walletAddressCooldownEndsAt ?? walletAddressCooldownEndsAt;
            walletAddressValue.textContent = getWalletAddressDisplayValue(currentWalletAddress);
            walletAddressInput.value = currentWalletAddress;
            setWalletEditMode(false);
          } catch (error) {
            walletAddressInput.setCustomValidity(error instanceof Error ? error.message : 'Unable to save wallet address.');
            walletAddressInput.reportValidity();
            walletAddressInput.focus();
          } finally {
            isSavingWalletAddress = false;
            syncWalletCooldownState();
          }
        };

        const cancelWalletAddressEdit = () => {
          if (isSavingWalletAddress) return;
          walletAddressInput.value = currentWalletAddress;
          walletAddressInput.setCustomValidity('');
          setWalletEditMode(false);
        };

        walletAddressToggle.addEventListener('click', async () => {
          if (isSavingWalletAddress) return;

          if (walletAddressInput.hidden && !syncWalletCooldownState()) {
            return;
          }

          if (walletAddressInput.hidden) {
            setWalletEditMode(true);
            return;
          }

          await saveWalletAddress();
        });

        walletAddressInput.addEventListener('keydown', async (event) => {
          if (event.key === 'Enter') {
            event.preventDefault();
            await saveWalletAddress();
          }

          if (event.key === 'Escape') {
            cancelWalletAddressEdit();
          }
        });

        walletAddressInput.addEventListener('input', () => {
          walletAddressInput.setCustomValidity('');
        });

        document.addEventListener('pointerdown', (event) => {
          if (walletAddressInput.hidden) return;
          if (!(event.target instanceof Node)) return;
          if (walletAddressCard.contains(event.target)) return;
          cancelWalletAddressEdit();
        });

        syncWalletCooldownState();
        walletAddressValue.textContent = getWalletAddressDisplayValue(currentWalletAddress);
        syncWalletFilledState();
      }

      const linkGenerator = document.querySelector('[data-link-generator]');
      if (linkGenerator instanceof HTMLElement) {
        const campaignNameInput = linkGenerator.querySelector('[data-link-campaign-name]');
        const campaignTagInput = linkGenerator.querySelector('[data-link-campaign-tag]');
        const generatedLinkInput = linkGenerator.querySelector('[data-generated-link]');
        const generateLinkButton = linkGenerator.querySelector('[data-generate-link]');
        const savedLinksList = document.querySelector('[data-saved-links-list]');
        const savedLinksCount = document.querySelector('[data-link-count]');
        const toastNode = document.querySelector('[data-link-toast]');
        const toastTitleNode = document.querySelector('[data-link-toast-title]');
        const toastCopyNode = document.querySelector('[data-link-toast-copy]');
        const baseUrl = linkGenerator.dataset.baseUrl ?? '';
        const partnerUsername = linkGenerator.dataset.partnerUsername ?? '';
        const generateButtonLabels = {
          idle: 'Generate Link',
          pending: 'Generating...',
          complete: 'Generated',
        };
        let toastTimer = null;
        let hasAttemptedGenerate = false;

        if (
          campaignNameInput instanceof HTMLInputElement &&
          campaignTagInput instanceof HTMLInputElement &&
          generatedLinkInput instanceof HTMLInputElement
        ) {
        const defaultGeneratedLinkPlaceholder = generatedLinkInput.getAttribute('placeholder') ?? '';

        const setGenerateButtonState = (state) => {
          if (!(generateLinkButton instanceof HTMLButtonElement)) {
            return;
          }

          generateLinkButton.textContent = generateButtonLabels[state];
          generateLinkButton.dataset.state = state;
          generateLinkButton.disabled = state !== 'idle';
        };

        const showLinkToast = (title, copy, tone = 'success') => {
          if (
            !(toastNode instanceof HTMLElement) ||
            !(toastTitleNode instanceof HTMLElement) ||
            !(toastCopyNode instanceof HTMLElement)
          ) {
            return;
          }

          toastTitleNode.textContent = title;
          toastCopyNode.textContent = copy;
          toastNode.dataset.tone = tone;
          toastNode.hidden = false;
          toastNode.dataset.visible = 'true';

          if (toastTimer !== null) {
            window.clearTimeout(toastTimer);
          }

          toastTimer = window.setTimeout(() => {
            toastNode.dataset.visible = 'false';
            window.setTimeout(() => {
              toastNode.hidden = true;
            }, 220);
          }, 2800);
        };

        const getFieldLabel = (input) => {
          if (!(input instanceof HTMLInputElement)) {
            return '';
          }

          return input.id === 'campaign-name' ? 'Campaign name' : 'Campaign tag';
        };

        const getDuplicateToastCopy = (duplicateField) => {
          if (duplicateField === 'campaignName') {
            return 'This campaign name already has a saved link.';
          }

          if (duplicateField === 'campaignNameAndTag') {
            return 'This campaign name and campaign tag already have saved links.';
          }

          return 'This campaign tag already has a saved link.';
        };

        const setFieldWarning = (input, isInvalid) => {
          if (!(input instanceof HTMLInputElement)) {
            return;
          }

          input.toggleAttribute('aria-invalid', isInvalid);
          input.closest('[data-link-field]')?.toggleAttribute('data-invalid', isInvalid);
        };

        const validateLinkInputs = ({ showWarnings = false } = {}) => {
          const requiredInputs = [campaignNameInput, campaignTagInput];
          const missingLabels = [];

          requiredInputs.forEach((input) => {
            const isEmpty = input.value.trim().length === 0;
            if (showWarnings) {
              setFieldWarning(input, isEmpty);
            }
            if (isEmpty) {
              missingLabels.push(getFieldLabel(input));
            }
          });

          return {
            isValid: missingLabels.length === 0,
            missingLabels,
          };
        };

        const buildPreviewUrl = () => {
          if (!partnerUsername.trim()) {
            return '';
          }

          const campaignTag = campaignTagInput.value.trim();
          if (!campaignTag) {
            return '';
          }

          const url = new URL(baseUrl);
          url.searchParams.set('pid', partnerUsername.trim());
          url.searchParams.set('cmp', campaignTag);
          return url.toString();
        };

        const syncGeneratedUrlDisplay = () => {
          if (!(generatedLinkInput instanceof HTMLInputElement)) {
            return;
          }

          const previewUrl = buildPreviewUrl();
          const hasCampaignName = campaignNameInput.value.trim().length > 0;

          if (!previewUrl) {
            generatedLinkInput.value = '';
            generatedLinkInput.placeholder = defaultGeneratedLinkPlaceholder;
            return;
          }

          if (hasCampaignName) {
            generatedLinkInput.value = previewUrl;
            generatedLinkInput.placeholder = defaultGeneratedLinkPlaceholder;
            return;
          }

          generatedLinkInput.value = '';
          generatedLinkInput.placeholder = previewUrl;
        };

        const buildGeneratedUrl = () => {
          if (
            !(generatedLinkInput instanceof HTMLInputElement)
          ) {
            return '';
          }

          const validation = validateLinkInputs({ showWarnings: hasAttemptedGenerate });
          if (!validation.isValid) {
            syncGeneratedUrlDisplay();
            setGenerateButtonState('idle');
            return '';
          }

          if (!partnerUsername.trim()) {
            generatedLinkInput.value = '';
            setGenerateButtonState('idle');
            return '';
          }

          const previewUrl = buildPreviewUrl();
          generatedLinkInput.placeholder = defaultGeneratedLinkPlaceholder;
          generatedLinkInput.value = previewUrl;
          return generatedLinkInput.value;
        };

        const refreshGeneratedUrlPreview = () => {
          syncGeneratedUrlDisplay();
        };

        const copyText = async (text) => {
          try {
            await navigator.clipboard.writeText(text);
            showLinkToast('Copied', 'Link copied to clipboard.');
          } catch {
            console.warn('[partner-web] Clipboard access is unavailable.');
            showLinkToast('Clipboard unavailable', 'Your browser blocked clipboard access.', 'warning');
          }
        };

        const downloadQrForLink = async (url) => {
          const qrUrl = `https://api.qrserver.com/v1/create-qr-code/?size=1024x1024&data=${encodeURIComponent(url)}`;
          try {
            const response = await fetch(qrUrl);
            if (!response.ok) throw new Error('QR request failed');
            const qrBlob = await response.blob();
            const objectUrl = URL.createObjectURL(qrBlob);
            const downloadAnchor = document.createElement('a');
            downloadAnchor.href = objectUrl;
            downloadAnchor.download = 'ramp2swap-referral-qr.png';
            document.body.appendChild(downloadAnchor);
            downloadAnchor.click();
            downloadAnchor.remove();
            URL.revokeObjectURL(objectUrl);
            showLinkToast('QR downloaded', 'QR export has started.', 'success');
          } catch {
            window.open(qrUrl, '_blank', 'noopener,noreferrer');
            showLinkToast('QR opened', 'QR code opened in a new tab.', 'success');
          }
        };

        const renderSavedLinkRow = (link) => `
          <article class="link-campaign-row" data-link-id="${link.id}">
            <div class="link-campaign-head">
              <div class="stack-8">
                <p class="heading-card">${link.campaignName}</p>
                <p class="data-small">${link.campaignTag}</p>
              </div>
              <span class="link-inline-stat">${new Date(link.createdAt)
                .toISOString()
                .slice(2, 10)
                .replace(/-/g, '/')}</span>
            </div>
            <p class="link-url">${link.generatedUrl}</p>
            <div class="link-campaign-meta">
              <button class="link-delete-button" type="button" data-delete-link-id="${link.id}" aria-label="Delete generated link">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M4 7h16"></path>
                  <path d="M10 11v6"></path>
                  <path d="M14 11v6"></path>
                  <path d="M6 7l1 12h10l1-12"></path>
                  <path d="M9 7V4h6v3"></path>
                </svg>
              </button>
              <div class="link-row-actions">
                <button class="link-action-button" type="button" data-download-qr-link="${link.generatedUrl}" aria-label="Download QR code">
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M4 4h6v6H4z"></path>
                    <path d="M14 4h6v6h-6z"></path>
                    <path d="M4 14h6v6H4z"></path>
                    <path d="M14 14h2"></path>
                    <path d="M18 14h2v2"></path>
                    <path d="M14 18h2v2h-2z"></path>
                    <path d="M18 18h2"></path>
                  </svg>
                </button>
                <button class="link-action-button" type="button" data-copy-text="${link.generatedUrl}" aria-label="Copy generated link">
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <rect x="9" y="9" width="10" height="10" rx="2"></rect>
                    <path d="M6 15H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v1"></path>
                  </svg>
                </button>
              </div>
            </div>
          </article>
        `;

        const bindCopyButtons = (scope = document) => {
          scope.querySelectorAll('[data-copy-text]').forEach((button) => {
            if (!(button instanceof HTMLElement) || button.dataset.copyBound === 'true') {
              return;
            }

            button.dataset.copyBound = 'true';
            button.addEventListener('click', async () => {
              const text = button.getAttribute('data-copy-text');
              if (!text) return;
              await copyText(text);
            });
          });
        };

        const bindQrButtons = (scope = document) => {
          scope.querySelectorAll('[data-download-qr-link]').forEach((button) => {
            if (!(button instanceof HTMLButtonElement) || button.dataset.qrBound === 'true') {
              return;
            }

            button.dataset.qrBound = 'true';
            button.addEventListener('click', async () => {
              const url = button.dataset.downloadQrLink ?? '';
              if (!url) return;
              await downloadQrForLink(url);
            });
          });
        };

        const updateSavedLinksCount = (nextCount) => {
          if (savedLinksCount instanceof HTMLElement) {
            savedLinksCount.textContent = `${Math.max(nextCount, 0)} active`;
          }
        };

        const ensureEmptySavedLinksState = () => {
          if (!(savedLinksList instanceof HTMLElement)) {
            return;
          }

          if (savedLinksList.querySelector('[data-link-id]')) {
            return;
          }

          savedLinksList.innerHTML = `
            <article class="link-campaign-row link-campaign-row-empty" data-empty-links-state>
              <p class="body-small empty-state-copy">Generated links will appear here as soon as you create your first campaign.</p>
            </article>
          `;
        };

        const bindDeleteButtons = (scope = document) => {
          scope.querySelectorAll('[data-delete-link-id]').forEach((button) => {
            if (!(button instanceof HTMLButtonElement) || button.dataset.deleteBound === 'true') {
              return;
            }

            button.dataset.deleteBound = 'true';
            button.addEventListener('click', async () => {
              const linkId = button.dataset.deleteLinkId ?? '';
              if (!linkId) return;

              button.disabled = true;

              try {
                const response = await fetch('/api/link/delete', {
                  method: 'POST',
                  headers: {
                    'Content-Type': 'application/json',
                  },
                  body: JSON.stringify({ linkId }),
                });

                const payload = (await response.json().catch(() => null)) as { ok?: boolean; error?: string } | null;
                if (!response.ok || !payload?.ok) {
                  throw new Error(payload?.error ?? 'Unable to delete link.');
                }

                const row = button.closest('[data-link-id]');
                row?.remove();
                const remainingLinks = savedLinksList instanceof HTMLElement ? savedLinksList.querySelectorAll('[data-link-id]').length : 0;
                updateSavedLinksCount(remainingLinks);
                ensureEmptySavedLinksState();
                showLinkToast('Link deleted', 'Campaign link removed from your dashboard.', 'success');
              } catch (error) {
                button.disabled = false;
                showLinkToast('Delete failed', error instanceof Error ? error.message : 'Unable to delete link.', 'warning');
              }
            });
          });
        };

        const prependSavedLink = (link) => {
          if (!(savedLinksList instanceof HTMLElement)) {
            return;
          }

          const existingRow = savedLinksList.querySelector(`[data-link-id="${link.id}"]`);
          if (existingRow instanceof HTMLElement) {
            savedLinksList.prepend(existingRow);
            const nextCount = savedLinksList.querySelectorAll('[data-link-id]').length;
            updateSavedLinksCount(nextCount);
            return;
          }

          savedLinksList.querySelector('[data-empty-links-state]')?.remove();
          savedLinksList.insertAdjacentHTML('afterbegin', renderSavedLinkRow(link));
          const insertedRow = savedLinksList.querySelector(`[data-link-id="${link.id}"]`);
          if (insertedRow instanceof HTMLElement) {
            bindCopyButtons(insertedRow);
            bindQrButtons(insertedRow);
            bindDeleteButtons(insertedRow);
          }

          const nextCount = savedLinksList.querySelectorAll('[data-link-id]').length;
          updateSavedLinksCount(nextCount);
        };
        generatedLinkInput.value = '';
        setGenerateButtonState('idle');

        [campaignNameInput, campaignTagInput].forEach((input) => {
          if (input instanceof HTMLInputElement) {
            input.addEventListener('input', () => {
              hasAttemptedGenerate = false;
              setFieldWarning(input, false);
              refreshGeneratedUrlPreview();
              setGenerateButtonState('idle');
            });
          }
        });

        if (generateLinkButton instanceof HTMLButtonElement) {
          generateLinkButton.addEventListener('click', async () => {
            hasAttemptedGenerate = true;
            const validation = validateLinkInputs({ showWarnings: true });
            if (!validation.isValid) {
              generatedLinkInput.value = '';
              setGenerateButtonState('idle');
              showLinkToast('Missing details', `${validation.missingLabels.join(' and ')} ${validation.missingLabels.length > 1 ? 'are' : 'is'} required.`, 'warning');
              return;
            }

            if (!partnerUsername.trim()) {
              generatedLinkInput.value = '';
              setGenerateButtonState('idle');
              showLinkToast('Username unavailable', 'Your partner username is required before a link can be generated.', 'warning');
              return;
            }

            setGenerateButtonState('pending');
            await new Promise((resolve) => window.requestAnimationFrame(() => resolve(undefined)));
            const url = buildGeneratedUrl();
            if (!url) {
              setGenerateButtonState('idle');
              return;
            }

            try {
              const response = await fetch('/api/link/generate', {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                  campaignName: campaignNameInput.value.trim(),
                  campaignTag: campaignTagInput.value.trim(),
                }),
              });

              const payload = (await response.json().catch(() => null)) as
                | {
                    ok?: boolean;
                    error?: string;
                    duplicate?: boolean;
                    duplicateField?: 'campaignName' | 'campaignTag' | 'campaignNameAndTag' | null;
                    link?: {
                      id: string;
                      campaignName: string;
                      campaignTag: string;
                      generatedUrl: string;
                      createdAt: number;
                    };
                  }
                | null;

              if (!response.ok || !payload?.ok || !payload.link) {
                throw new Error(payload?.error ?? 'Unable to generate link.');
              }

              generatedLinkInput.value = payload.link.generatedUrl;

              if (payload.duplicate) {
                prependSavedLink(payload.link);
                setGenerateButtonState('idle');
                showLinkToast('Already generated', getDuplicateToastCopy(payload.duplicateField), 'warning');
                return;
              }

              prependSavedLink(payload.link);
              setGenerateButtonState('complete');
              showLinkToast('Link saved', 'Campaign link generated and stored.', 'success');
            } catch (error) {
              setGenerateButtonState('idle');
              showLinkToast('Generation failed', error instanceof Error ? error.message : 'Unable to generate link.', 'warning');
            }
          });
        }

        bindCopyButtons();
        bindQrButtons();
        bindDeleteButtons();
        }
      }

      const transactionFeed = document.querySelector('[data-transaction-feed]');
      if (transactionFeed instanceof HTMLElement) {
        const refreshButton = document.querySelector('[data-refresh-transactions]');
        const transactionCount = document.querySelector('[data-transaction-count]');
        const transactionFeedBody = transactionFeed.querySelector('[data-transaction-feed-body]');
        const toastNode = document.querySelector('[data-link-toast]');
        const toastTitleNode = document.querySelector('[data-link-toast-title]');
        const toastCopyNode = document.querySelector('[data-link-toast-copy]');
        const username = transactionFeed.dataset.transactionUsername ?? '';
        let transactionToastTimer = null;

        const showTransactionToast = (title, copy, tone = 'success') => {
          if (
            !(toastNode instanceof HTMLElement) ||
            !(toastTitleNode instanceof HTMLElement) ||
            !(toastCopyNode instanceof HTMLElement)
          ) {
            return;
          }

          toastTitleNode.textContent = title;
          toastCopyNode.textContent = copy;
          toastNode.dataset.tone = tone;
          toastNode.hidden = false;
          toastNode.dataset.visible = 'true';

          if (transactionToastTimer !== null) {
            window.clearTimeout(transactionToastTimer);
          }

          transactionToastTimer = window.setTimeout(() => {
            toastNode.dataset.visible = 'false';
            window.setTimeout(() => {
              toastNode.hidden = true;
            }, 220);
          }, 2800);
        };

        const escapeHtml = (value) =>
          String(value)
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#39;');

        const renderTransactionFeed = (items) => {
          if (!(transactionFeedBody instanceof HTMLElement)) {
            return;
          }

          if (transactionCount instanceof HTMLElement) {
            transactionCount.textContent = `${items.length} recent entries`;
          }

          if (items.length === 0) {
            transactionFeedBody.innerHTML = `
              <div class="transaction-empty-state">
                <article class="link-campaign-row link-campaign-row-empty transaction-empty-card">
                  <p class="body-small empty-state-copy">No attributed transactions yet.</p>
                </article>
              </div>
            `;
            return;
          }

          transactionFeedBody.innerHTML = `
            <div class="table-wrap transaction-table-wrap">
              <table class="table">
                <thead>
                  <tr>
                    <th>Transaction</th>
                    <th>Status</th>
                    <th>AMOUNT($)</th>
                    <th>Pair</th>
                    <th>Timestamp</th>
                    <th>User</th>
                  </tr>
                </thead>
                <tbody>
                  ${items
                    .map(
                      (tx) => `
                        <tr>
                          <td>${escapeHtml(tx.id)}</td>
                          <td>
                            <span class="status ${tx.status === 'completed' ? 'status-completed' : tx.status === 'pending' ? 'status-pending' : 'status-failed'}">
                              ${escapeHtml(tx.status)}
                            </span>
                          </td>
                          <td>${escapeHtml(tx.amount)}</td>
                          <td>${escapeHtml(tx.pair)}</td>
                          <td>${escapeHtml(tx.timestamp)}</td>
                          <td>${escapeHtml(tx.user)}</td>
                        </tr>
                      `,
                    )
                    .join('')}
                </tbody>
              </table>
            </div>
          `;
        };

        if (refreshButton instanceof HTMLButtonElement) {
          refreshButton.addEventListener('click', async () => {
            if (!username.trim()) {
              showTransactionToast('Refresh unavailable', 'Partner username is required to refresh the referral stream.', 'warning');
              return;
            }

            refreshButton.disabled = true;
            refreshButton.dataset.state = 'pending';

            try {
              const response = await fetch('/api/transaction/feed', {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/json',
                },
                body: JSON.stringify({ username }),
              });

              const payload = (await response.json().catch(() => null)) as
                | {
                    ok?: boolean;
                    error?: string;
                    transactions?: Array<{
                      id: string;
                      status: string;
                      amount: string;
                      pair: string;
                      timestamp: string;
                      user: string;
                    }>;
                  }
                | null;

              if (!response.ok || !payload?.ok || !Array.isArray(payload.transactions)) {
                throw new Error(payload?.error ?? 'Unable to refresh referral stream.');
              }

              renderTransactionFeed(payload.transactions);
              showTransactionToast('Referral stream refreshed', 'Latest attributed transactions loaded.');
            } catch (error) {
              showTransactionToast(
                'Refresh failed',
                error instanceof Error ? error.message : 'Unable to refresh referral stream.',
                'warning',
              );
            } finally {
              refreshButton.disabled = false;
              refreshButton.dataset.state = 'idle';
            }
          });
        }
      }

      const analyticsChart = document.querySelector('[data-analytics-chart]');
      if (analyticsChart instanceof HTMLElement) {
        const rangeLabel = analyticsChart.querySelector('[data-analytics-range-label]');
        const barsContainer = analyticsChart.querySelector('[data-analytics-bars]');
        const rangeButtons = analyticsChart.querySelectorAll('[data-range-toggle]');
        const rangesJson = analyticsChart.dataset.analyticsRanges ?? '';

        const escapeAnalyticsHtml = (value) =>
          String(value)
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#39;');

        const renderAnalyticsBars = (points) =>
          points
            .map(
              (point) => `
                <button
                  class="bar-button"
                  type="button"
                  data-bar-label="${escapeAnalyticsHtml(point.label)}"
                  data-bar-clicks="${Number(point.clicks) || 0}"
                  data-bar-conversion="${escapeAnalyticsHtml(point.conversionRate)}"
                  aria-label="${escapeAnalyticsHtml(point.label)}: ${Number(point.clicks) || 0} clicks, ${escapeAnalyticsHtml(point.conversionRate)} conversion rate"
                  style="height: ${Math.max(0, Number(point.height) || 0)}%"
                >
                  <span class="bar-fill"></span>
                </button>
              `,
            )
            .join('');

        try {
          const parsedRanges = JSON.parse(rangesJson);
          const getRange = (rangeKey) => {
            if (!parsedRanges || typeof parsedRanges !== 'object') {
              return null;
            }

            const candidate = parsedRanges[rangeKey];
            if (
              !candidate ||
              typeof candidate !== 'object' ||
              !Array.isArray(candidate.points) ||
              typeof candidate.timeRangeLabel !== 'string'
            ) {
              return null;
            }

            return candidate;
          };

          const setActiveRange = (rangeKey) => {
            const nextRange = getRange(rangeKey);
            if (!nextRange || !(rangeLabel instanceof HTMLElement) || !(barsContainer instanceof HTMLElement)) {
              return;
            }

            rangeLabel.textContent = nextRange.timeRangeLabel;
            barsContainer.innerHTML = renderAnalyticsBars(nextRange.points);
            rangeButtons.forEach((button) => {
              button.classList.toggle('analytics-range-button-active', button.getAttribute('data-range-toggle') === rangeKey);
            });
          };

          rangeButtons.forEach((button) => {
            button.addEventListener('click', () => {
              const rangeKey = button.getAttribute('data-range-toggle');
              if (!rangeKey) {
                return;
              }

              setActiveRange(rangeKey);
            });
          });
        } catch (error) {
          console.warn('[partner-web] failed to initialize analytics chart', error);
        }
      }

      document.querySelectorAll('[data-analytics-breakdown-card]').forEach((card) => {
        if (!(card instanceof HTMLElement)) {
          return;
        }

        const body = card.querySelector('[data-analytics-breakdown-body]');
        const rangeButtons = card.querySelectorAll('[data-breakdown-range-toggle]');
        const rangesJson = card.dataset.analyticsBreakdownRanges ?? '';

        const escapeBreakdownHtml = (value) =>
          String(value)
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#39;');

        const formatBreakdownPct = (pct) => {
          const numeric = Number(pct) || 0;
          return Number.isInteger(numeric) ? `${numeric.toFixed(0)}%` : `${numeric.toFixed(1)}%`;
        };

        const renderBreakdownRows = (items) =>
          items
            .map(
              (item) => `
                <div class="progress-row">
                  <button
                    class="analytics-breakdown-button"
                    type="button"
                    data-breakdown-label="${escapeBreakdownHtml(item.label)}"
                    data-breakdown-clicks="${Number(item.clicks) || 0}"
                    data-breakdown-conversions="${Number(item.conversions) || 0}"
                    data-breakdown-conversion="${escapeBreakdownHtml(item.conversionRate)}"
                    data-breakdown-percent="${formatBreakdownPct(item.pct)}"
                    aria-label="${escapeBreakdownHtml(item.label)}: ${Number(item.clicks) || 0} clicks, ${Number(item.conversions) || 0} conversions, ${escapeBreakdownHtml(item.conversionRate)} conversion rate, ${formatBreakdownPct(item.pct)} share"
                  >
                    <div class="row-12 analytics-progress-head">
                      <span class="body-small">${escapeBreakdownHtml(item.label)}</span>
                      <span class="data-small">${formatBreakdownPct(item.pct)}</span>
                    </div>
                    <div class="progress-track">
                      <div class="progress-fill" style="width: ${Math.max(0, Number(item.pct) || 0)}%;"></div>
                    </div>
                  </button>
                </div>
              `,
            )
            .join('');

        try {
          const parsedRanges = JSON.parse(rangesJson);
          const getRangeItems = (rangeKey) => {
            if (!parsedRanges || typeof parsedRanges !== 'object') {
              return null;
            }

            const candidate = parsedRanges[rangeKey];
            if (!Array.isArray(candidate)) {
              return null;
            }

            return candidate;
          };

          const setActiveRange = (rangeKey) => {
            const nextItems = getRangeItems(rangeKey);
            if (!Array.isArray(nextItems) || !(body instanceof HTMLElement)) {
              return;
            }

            body.innerHTML = renderBreakdownRows(nextItems);
            rangeButtons.forEach((button) => {
              button.classList.toggle('analytics-range-button-active', button.getAttribute('data-breakdown-range-toggle') === rangeKey);
            });
          };

          rangeButtons.forEach((button) => {
            button.addEventListener('click', () => {
              const rangeKey = button.getAttribute('data-breakdown-range-toggle');
              if (!rangeKey) {
                return;
              }

              setActiveRange(rangeKey);
            });
          });
        } catch (error) {
          console.warn('[partner-web] failed to initialize analytics breakdown card', error);
        }
      });

    </script>
  </body>
</html>
