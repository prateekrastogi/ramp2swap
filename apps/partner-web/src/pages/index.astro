---
import '../styles/design-system.css';
import { earningsSummary, payoutHistoryEntries } from '../data/earnings-payouts-mock';
import { linkGeneratorDraft, savedCampaignLinks } from '../data/link-generator-mock';
import { performanceSnapshotMetrics } from '../data/performance-snapshot-mock';
import { transactionFeedItems } from '../data/transaction-feed-mock';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Ramp2Swap partner portal" />
    <title>Ramp2Swap Partner Portal</title>
    <link rel="icon" type="image/png" href="/logo.png" />
  </head>
  <body class="page">
    <input id="sidebar-collapse" class="sidebar-control" type="checkbox" />
    <input id="sidebar-pin" class="sidebar-control" type="checkbox" />
    <input id="sidebar-mobile" class="sidebar-control" type="checkbox" />

    <div class="ambient-layer" aria-hidden="true">
      <div class="ambient-orb ambient-orb--mint-top"></div>
      <div class="ambient-orb ambient-orb--blue-bottom"></div>
      <div class="ambient-orb ambient-orb--mint-center"></div>
    </div>

    <header class="mobile-topbar content-layer">
      <label for="sidebar-mobile" class="hamburger-btn" aria-label="Open navigation">
        <svg class="hamburger-icon" viewBox="0 0 24 24" aria-hidden="true">
          <line class="hamburger-line hamburger-line-top" x1="5" y1="7" x2="19" y2="7"></line>
          <line class="hamburger-line hamburger-line-mid" x1="5" y1="12" x2="19" y2="12"></line>
          <line class="hamburger-line hamburger-line-bottom" x1="5" y1="17" x2="19" y2="17"></line>
        </svg>
      </label>
      <label for="sidebar-mobile" class="mobile-topbar-logo-toggle" aria-label="Toggle navigation">
        <img class="logo-mark mobile-topbar-mark" src="/logo.png" alt="Ramp2Swap mark" />
      </label>
    </header>

    <label for="sidebar-mobile" class="mobile-overlay" aria-hidden="true"></label>

    <main class="dashboard-shell content-layer">
      <aside class="sidebar glass on-glass">
        <button class="sidebar-brand" id="sidebar-brand-toggle" type="button" aria-label="Toggle navigation">
          <img class="logo-horizontal sidebar-logo-horizontal" src="/logo_horizontal.png" alt="Ramp2Swap" />
          <img class="logo-mark sidebar-logo-mark" src="/logo.png" alt="Ramp2Swap mark" />
        </button>

        <nav class="sidebar-nav" aria-label="Primary navigation">
          <section class="nav-section">
            <a class="nav-item nav-item-active" href="#overview" data-label="Overview" data-view-target="overview"><span class="nav-icon">◫</span><span class="nav-text">Overview</span></a>
            <a class="nav-item" href="#link-generator" data-label="Link Generator" data-view-target="link-generator"><span class="nav-icon">⛓</span><span class="nav-text">Link Generator</span></a>
            <a class="nav-item" href="#transaction-feed" data-label="Transaction Feed" data-view-target="transaction-feed"><span class="nav-icon">⇄</span><span class="nav-text">Transaction Feed</span></a>
            <a class="nav-item" href="#earnings-payouts" data-label="Earnings & Payouts" data-view-target="earnings-payouts"><span class="nav-icon">$</span><span class="nav-text">Earnings & Payouts</span></a>
            <a class="nav-item" href="#" data-label="Analytics"><span class="nav-icon">◔</span><span class="nav-text">Analytics</span></a>
            <a class="nav-item" href="#" data-label="Branding Kit"><span class="nav-icon">▣</span><span class="nav-text">Branding Kit</span></a>
          </section>
        </nav>

        <div class="sidebar-bottom">
          <a class="nav-item" href="#" data-label="Settings"><span class="nav-icon">⚙</span><span class="nav-text">Settings</span></a>
          <a class="nav-item" href="#" data-label="Help"><span class="nav-icon">i</span><span class="nav-text">Help</span></a>

          <a class="sidebar-profile" href="#" data-label="Profile">
            <span class="sidebar-avatar"></span>
            <span class="profile-copy">
              <span class="profile-name">Partner Account</span>
              <span class="profile-role">PRO PLAN</span>
            </span>
            <span class="profile-chevron">›</span>
          </a>
        </div>
      </aside>

      <section class="dashboard-content" aria-label="Dashboard content area">
        <div class="dashboard-main">
          <section id="overview" class="overview-shell" data-dashboard-view="overview">
            <div class="dashboard-section-header">
              <div class="stack-12">
                <p class="ui-label">Overview</p>
                <h1 class="heading-card dashboard-section-title">Partner Performance Snapshot</h1>
                <p class="body dashboard-section-copy">
                  Core referral performance metrics for the current reporting window.
                </p>
              </div>
            </div>

            <div class="performance-metrics-grid">
              {performanceSnapshotMetrics.map((metric) => (
                <article class={`card performance-metric-card glass ${metric.accent === 'mint' ? 'glass-tier-2 glass-mint' : 'glass-tier-1'} on-glass`}>
                  <div class="performance-metric-card-top">
                    <p class="ui-label">{metric.label}</p>
                    <span class={`performance-metric-delta ${metric.accent === 'mint' ? 'performance-metric-delta-accent' : ''}`}>{metric.delta}</span>
                  </div>
                  <p class="data-large performance-metric-value">{metric.value}</p>
                  <p class="body-small performance-metric-detail">{metric.detail}</p>
                </article>
              ))}
            </div>
          </section>

          <section id="link-generator" class="link-generator-shell" data-dashboard-view="link-generator" hidden>
            <div class="dashboard-section-header">
              <div class="stack-12">
                <p class="ui-label">Link Generator</p>
                <h2 class="heading-card dashboard-section-title">Generate Referral Links</h2>
                <p class="body dashboard-section-copy">
                  Create partner-specific referral URLs, append campaign tags, and manage active links.
                </p>
              </div>
              <span class="chip">Campaign Links</span>
            </div>

            <div class="link-generator-grid">
              <article class="card glass glass-tier-2 glass-mint on-glass link-generator-card">
                <div class="widget-header">
                  <p class="heading-card">Primary Link Builder</p>
                  <span class="badge-active">Core Flow</span>
                </div>

                <div class="link-form-grid" data-link-generator data-base-url={linkGeneratorDraft.baseUrl}>
                  <div class="stack-12">
                    <label class="ui-label" for="partner-id">Partner ID</label>
                    <input id="partner-id" class="input input-glass" data-link-partner-id value={linkGeneratorDraft.partnerId} />
                  </div>

                  <div class="stack-12">
                    <label class="ui-label" for="campaign-tag">Campaign Tag</label>
                    <input id="campaign-tag" class="input input-glass" data-link-campaign-tag value={linkGeneratorDraft.campaignTag} />
                  </div>

                  <div class="stack-12 link-output-block">
                    <label class="ui-label" for="generated-link">Generated Referral URL</label>
                    <div class="link-output-shell">
                      <input
                        id="generated-link"
                        class="input input-glass link-output-input"
                        data-generated-link
                        value={linkGeneratorDraft.generatedUrl}
                        readonly
                      />
                      <div class="link-output-actions">
                        <button class="btn-primary btn-glass" type="button" data-generate-link>Generate Link</button>
                        <button class="btn-secondary" type="button" data-copy-generated-link>Copy Link</button>
                        <button class="btn-secondary" type="button" data-download-qr>Download QR</button>
                      </div>
                    </div>
                    <p class="data-small link-generator-feedback" data-link-feedback aria-live="polite"></p>
                  </div>
                </div>
              </article>

              <article class="card glass glass-tier-1 on-glass link-campaigns-card">
                <div class="widget-header">
                  <p class="heading-card">Saved Campaign Links</p>
                  <span class="chip">{savedCampaignLinks.length} active</span>
                </div>

                <div class="link-campaign-list">
                  {savedCampaignLinks.map((link) => (
                    <article class="link-campaign-row">
                      <div class="link-campaign-head">
                        <div class="stack-8">
                          <p class="heading-card">{link.name}</p>
                          <p class="data-small">{link.tag}</p>
                        </div>
                        <span class="link-inline-stat">{link.clicks} clicks</span>
                      </div>

                      <p class="link-url">{link.url}</p>

                      <div class="link-campaign-meta">
                        <span class="link-inline-stat">{link.conversions} conversions</span>
                        <button class="btn-secondary link-inline-btn" type="button" data-copy-text={link.url}>Copy</button>
                      </div>
                    </article>
                  ))}
                </div>
              </article>
            </div>
          </section>

          <section id="transaction-feed" class="transaction-feed-shell" data-dashboard-view="transaction-feed" hidden>
            <div class="dashboard-section-header">
              <div class="stack-12">
                <p class="ui-label">Transaction Feed</p>
                <h2 class="heading-card dashboard-section-title">Live Processing Status</h2>
                <p class="body dashboard-section-copy">
                  Every ramp transaction attributed to your referral links, with anonymized user references and current processing status.
                </p>
              </div>
              <span class="chip">Anonymized Users</span>
            </div>

            <article class="card glass glass-tier-1 on-glass transaction-feed-card">
              <div class="widget-header">
                <p class="heading-card">Referral Stream</p>
                <span class="chip">{transactionFeedItems.length} recent entries</span>
              </div>

              <div class="table-wrap transaction-table-wrap">
                <table class="table">
                  <thead>
                    <tr>
                      <th>Transaction</th>
                      <th>Status</th>
                      <th>Amount</th>
                      <th>Pair</th>
                      <th>Timestamp</th>
                      <th>User</th>
                    </tr>
                  </thead>
                  <tbody>
                    {transactionFeedItems.map((tx) => (
                      <tr>
                        <td>{tx.id}</td>
                        <td>
                          <span class={`status ${tx.status === 'completed' ? 'status-completed' : tx.status === 'pending' ? 'status-pending' : 'status-failed'}`}>
                            {tx.status}
                          </span>
                        </td>
                        <td>{tx.amount}</td>
                        <td>{tx.pair}</td>
                        <td>{tx.timestamp}</td>
                        <td>{tx.user}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </article>
          </section>

          <section id="earnings-payouts" class="earnings-payouts-shell" data-dashboard-view="earnings-payouts" hidden>
            <div class="dashboard-section-header">
              <div class="stack-12">
                <p class="ui-label">Earnings & Payouts</p>
                <h2 class="heading-card dashboard-section-title">Commission and Withdrawal Status</h2>
                <p class="body dashboard-section-copy">
                  Review your commission rate, compare pending versus available balance, and track payout history before requesting withdrawal.
                </p>
              </div>
            </div>

            <div class="earnings-payouts-grid">
              <article class="card glass glass-tier-2 glass-mint on-glass earnings-summary-card">
                <div class="widget-header">
                  <p class="heading-card">Commission Snapshot</p>
                  <span class="badge-active">Action Surface</span>
                </div>

                <div class="kpi-grid earnings-kpi-grid">
                  <div class="kpi-card">
                    <p class="ui-label">Commission Rate</p>
                    <p class="data-large">{earningsSummary.commissionRate}</p>
                  </div>
                  <div class="kpi-card">
                    <p class="ui-label">Pending Balance</p>
                    <p class="data-large">{earningsSummary.pendingBalance}</p>
                  </div>
                  <div class="kpi-card">
                    <p class="ui-label">Available Balance</p>
                    <p class="data-large">{earningsSummary.availableBalance}</p>
                  </div>
                  <div class="kpi-card">
                    <p class="ui-label">Total Paid Out</p>
                    <p class="data-large">{earningsSummary.totalPaidOut}</p>
                  </div>
                </div>

                <div class="row-12">
                  <button class="btn-primary btn-glass" type="button">Request Withdrawal</button>
                </div>
              </article>

              <article class="card glass glass-tier-1 on-glass payout-history-card">
                <div class="widget-header">
                  <p class="heading-card">Payout History</p>
                  <span class="chip">{payoutHistoryEntries.length} entries</span>
                </div>

                <div class="payout-history-list">
                  {payoutHistoryEntries.map((entry) => (
                    <article class="payout-history-row">
                      <div class="payout-history-head">
                        <div class="stack-8">
                          <p class="heading-card">{entry.amount}</p>
                          <p class="data-small">{entry.destination}</p>
                        </div>
                        <span class={`status ${entry.status === 'paid' ? 'status-completed' : 'status-pending'}`}>
                          {entry.status}
                        </span>
                      </div>

                      <div class="row-12 payout-history-meta">
                        <span class="data-small">{entry.date}</span>
                        <span class="chip">{entry.id}</span>
                      </div>
                    </article>
                  ))}
                </div>
              </article>
            </div>
          </section>
        </div>
      </section>
    </main>

    <script>
      const collapseControl = document.getElementById('sidebar-collapse');
      if (collapseControl instanceof HTMLInputElement && window.matchMedia('(min-width: 1280px)').matches) {
        collapseControl.checked = false;
      }

      const sidebarBrandToggle = document.getElementById('sidebar-brand-toggle');
      const mobileControl = document.getElementById('sidebar-mobile');
      const pinControl = document.getElementById('sidebar-pin');
      const navViewTriggers = document.querySelectorAll('[data-view-target]');
      const dashboardViews = document.querySelectorAll('[data-dashboard-view]');

      if (
        sidebarBrandToggle instanceof HTMLButtonElement &&
        mobileControl instanceof HTMLInputElement &&
        pinControl instanceof HTMLInputElement
      ) {
        sidebarBrandToggle.addEventListener('click', () => {
          if (window.matchMedia('(max-width: 767px)').matches) {
            mobileControl.checked = !mobileControl.checked;
            return;
          }

          if (window.matchMedia('(min-width: 768px) and (max-width: 1279px)').matches) {
            pinControl.checked = !pinControl.checked;
            return;
          }

          if (collapseControl instanceof HTMLInputElement) {
            collapseControl.checked = !collapseControl.checked;
          }
        });
      }

      if (navViewTriggers.length > 0 && dashboardViews.length > 0) {
        const setActiveView = (viewName) => {
          navViewTriggers.forEach((trigger) => {
            const isActive = trigger.getAttribute('data-view-target') === viewName;
            trigger.classList.toggle('nav-item-active', isActive);
          });

          dashboardViews.forEach((view) => {
            view.hidden = view.getAttribute('data-dashboard-view') !== viewName;
          });

          if (mobileControl instanceof HTMLInputElement && window.matchMedia('(max-width: 767px)').matches) {
            mobileControl.checked = false;
          }
        };

        navViewTriggers.forEach((trigger) => {
          trigger.addEventListener('click', (event) => {
            const target = trigger.getAttribute('data-view-target');
            if (!target) return;
            event.preventDefault();
            setActiveView(target);
          });
        });
      }

      const linkGenerator = document.querySelector('[data-link-generator]');
      if (linkGenerator instanceof HTMLElement) {
        const partnerIdInput = linkGenerator.querySelector('[data-link-partner-id]');
        const campaignTagInput = linkGenerator.querySelector('[data-link-campaign-tag]');
        const generatedLinkInput = linkGenerator.querySelector('[data-generated-link]');
        const generateLinkButton = linkGenerator.querySelector('[data-generate-link]');
        const copyGeneratedLinkButton = linkGenerator.querySelector('[data-copy-generated-link]');
        const downloadQrButton = linkGenerator.querySelector('[data-download-qr]');
        const feedbackNode = linkGenerator.querySelector('[data-link-feedback]');
        const baseUrl = linkGenerator.dataset.baseUrl ?? '';

        const setFeedback = (message) => {
          if (feedbackNode instanceof HTMLElement) {
            feedbackNode.textContent = message;
          }
        };

        const buildGeneratedUrl = () => {
          if (
            !(partnerIdInput instanceof HTMLInputElement) ||
            !(campaignTagInput instanceof HTMLInputElement) ||
            !(generatedLinkInput instanceof HTMLInputElement)
          ) {
            return '';
          }

          const url = new URL(baseUrl);
          const partnerId = partnerIdInput.value.trim();
          const campaignTag = campaignTagInput.value.trim();
          if (partnerId) url.searchParams.set('pid', partnerId);
          if (campaignTag) {
            url.searchParams.set('cmp', campaignTag);
          } else {
            url.searchParams.delete('cmp');
          }
          generatedLinkInput.value = url.toString();
          return generatedLinkInput.value;
        };

        const copyText = async (text, successMessage) => {
          try {
            await navigator.clipboard.writeText(text);
            setFeedback(successMessage);
          } catch {
            setFeedback('Clipboard permission unavailable');
          }
        };

        buildGeneratedUrl();

        [partnerIdInput, campaignTagInput].forEach((input) => {
          if (input instanceof HTMLInputElement) {
            input.addEventListener('input', () => {
              setFeedback('');
            });
          }
        });

        if (generateLinkButton instanceof HTMLButtonElement) {
          generateLinkButton.addEventListener('click', () => {
            buildGeneratedUrl();
            setFeedback('Referral link generated');
          });
        }

        if (copyGeneratedLinkButton instanceof HTMLButtonElement) {
          copyGeneratedLinkButton.addEventListener('click', async () => {
            const url = buildGeneratedUrl();
            if (!url) return;
            await copyText(url, 'Referral link copied');
          });
        }

        if (downloadQrButton instanceof HTMLButtonElement) {
          downloadQrButton.addEventListener('click', async () => {
            const url = buildGeneratedUrl();
            if (!url) return;
            const qrUrl = `https://api.qrserver.com/v1/create-qr-code/?size=1024x1024&data=${encodeURIComponent(url)}`;
            try {
              const response = await fetch(qrUrl);
              if (!response.ok) throw new Error('QR request failed');
              const qrBlob = await response.blob();
              const objectUrl = URL.createObjectURL(qrBlob);
              const downloadAnchor = document.createElement('a');
              downloadAnchor.href = objectUrl;
              downloadAnchor.download = 'ramp2swap-referral-qr.png';
              document.body.appendChild(downloadAnchor);
              downloadAnchor.click();
              downloadAnchor.remove();
              URL.revokeObjectURL(objectUrl);
              setFeedback('QR download started');
            } catch {
              window.open(qrUrl, '_blank', 'noopener,noreferrer');
              setFeedback('QR opened in a new tab');
            }
          });
        }

        document.querySelectorAll('[data-copy-text]').forEach((button) => {
          button.addEventListener('click', async () => {
            const text = button.getAttribute('data-copy-text');
            if (!text) return;
            await copyText(text, 'Campaign link copied');
          });
        });
      }
    </script>
  </body>
</html>
