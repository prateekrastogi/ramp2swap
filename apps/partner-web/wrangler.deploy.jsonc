{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "partner-web",
	"main": "./dist/server/entry.mjs",
	"compatibility_date": "2026-03-01",
	"compatibility_flags": [
		"nodejs_compat",
		"global_fetch_strictly_public"
	],
	"assets": {
		"binding": "ASSETS",
		"directory": "./dist/client"
	},
	"observability": {
		"enabled": true
	},
	"env": {
		"staging": {
			"name": "partner-web-staging"
		}
	}
}
