{
	"name": "main-web",
	"type": "module",
	"version": "0.0.1",
	"engines": {
		"node": ">=22.12.0"
	},
	"scripts": {
		"dev": "ASTRO_DISABLE_CLOUDFLARE_ADAPTER=true astro dev --port 1234",
		"check:design-system": "node ./scripts/check-design-system.mjs",
		"build": "npm run check:design-system && astro build",
		"preview": "npm run check:design-system && astro build && wrangler dev --config ./wrangler.deploy.jsonc",
		"astro": "astro",
		"deploy": "npm run check:design-system && astro build && wrangler deploy --config ./wrangler.deploy.jsonc",
		"cf-typegen": "wrangler types"
	},
	"dependencies": {
		"@astrojs/cloudflare": "^13.1.1",
		"@bigmi/react": "^0.7.1",
		"@lifi/widget": "^3.40.12",
		"@mysten/dapp-kit": "^1.0.4",
		"@solana/wallet-adapter-react": "^0.15.39",
		"@tanstack/react-query": "^5.91.3",
		"astro": "^6.0.4",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"wagmi": "^2.19.5"
	},
	"devDependencies": {
		"@astrojs/react": "^4.4.0",
		"@types/node": "^25.5.0",
		"wrangler": "^4.73.0"
	}
}
