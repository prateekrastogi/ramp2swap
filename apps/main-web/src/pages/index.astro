---
import '../styles/design-system.css';
import { WidgetSkeleton } from '@lifi/widget/skeleton';
import { createElement } from 'react';
import { renderToString } from 'react-dom/server';
import { getLiFiWidgetRuntimeConfig } from '../lib/lifi-config';

const runtime = getLiFiWidgetRuntimeConfig();
const widgetMarkup = renderToString(createElement(WidgetSkeleton, { config: runtime.config }));
const siteName = 'Ramp2Swap';
const siteDescription = 'One Interface. All of DeFi.';
const shareImage = '/logo.png';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={siteDescription} />
    <meta name="generator" content={Astro.generator} />
    <title>{siteDescription}</title>
    <link rel="icon" type="image/svg+xml" href="/Ramp2Swap.svg" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={siteName} />
    <meta property="og:description" content={siteDescription} />
    <meta property="og:image" content={shareImage} />
    <meta property="og:image:alt" content="Ramp2Swap logo" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteName} />
    <meta name="twitter:description" content={siteDescription} />
    <meta name="twitter:image" content={shareImage} />
    <meta name="twitter:image:alt" content="Ramp2Swap logo" />
  </head>
  <body class="page">
    <div class="ambient-layer" aria-hidden="true">
      <div class="ambient-orb ambient-orb--mint-top"></div>
      <div class="ambient-orb ambient-orb--blue-bottom"></div>
      <div class="ambient-orb ambient-orb--mint-center"></div>
    </div>

    <div class="main-app content-layer">
      <header class="main-header glass glass-tier-4-nav on-glass" aria-label="Primary header">
        <div class="brand-nav main-header-nav">
          <a class="brand-row main-header-brand" href="/" aria-label="Ramp2Swap home">
            <img
              class="logo-horizontal logo-nav-horizontal mobile-nav-horizontal-only main-header-logo"
              src="/Horizontal_Logo.svg"
              alt="Ramp2Swap"
            />
            <img class="logo-mark logo-mark-nav mobile-nav-mark-only" src="/Ramp2Swap.svg" alt="Ramp2Swap mark" />
          </a>

          <button
            class="btn-primary btn-glass main-header-cta"
            type="button"
            id="header-connect-wallet"
            data-wallet-state="disconnected"
            aria-label="Connect Wallet"
          >
            <span class="main-header-cta-desktop" id="header-connect-wallet-label-desktop">Connect Wallet</span>
            <span class="main-header-cta-mobile" id="header-connect-wallet-label-mobile">Connect</span>
          </button>
        </div>
      </header>

      <main class="main-stage" aria-label="Main web preview">
        <section class="widget-stage" aria-label="Swap widget">
          <div class="widget-stage-shell card glass glass-tier-2 on-glass">
            <div class="widget-stage-frame">
              <div id="lifi-widget-root" class="lifi-widget-mount" set:html={widgetMarkup}></div>
            </div>
            <section class="conversation-stage-frame" aria-label="Conversation upload composer">
              <div class="conversation-stage card glass glass-tier-1 on-glass">
                <label class="conversation-stage-label" for="conversation-upload-input">Intent AI</label>
                <div class="conversation-stage-input-shell">
                  <textarea
                    id="conversation-upload-input"
                    class="conversation-stage-input"
                    rows="1"
                    placeholder="Describe Your Swap..."
                    aria-label="Conversation input"
                  ></textarea>
                  <button class="btn-primary btn-glass conversation-stage-submit" type="button" aria-label="Upload conversation to AI">
                    <span class="conversation-stage-submit-label">Upload</span>
                  </button>
                </div>
              </div>
            </section>
          </div>
        </section>
      </main>
    </div>
    <script>
      import '../scripts/lifi-widget-mount.ts';

      const conversationInput = document.getElementById('conversation-upload-input');
      if (conversationInput instanceof HTMLTextAreaElement) {
        const resizeConversationInput = () => {
          conversationInput.style.height = 'auto';
          conversationInput.style.height = `${conversationInput.scrollHeight}px`;
        };

        resizeConversationInput();
        conversationInput.addEventListener('input', resizeConversationInput);
      }
    </script>
  </body>
</html>
